---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const categoryColors = {
  'Reisetipps': '#0EA5E9',
  'KI & Reisen': '#F97316',
  'Fernweh': '#10B981',
  'Unterwegs': '#8B5CF6',
  'Clever Reisen': '#0EA5E9',
  'Nur mit Handgepäck': '#F59E0B',
  'Traumunterkünfte': '#EC4899',
  'Business Travel': '#0F172A',
  'Nachhaltig': '#22C55E',
  'Geheimtipps': '#EF4444',
  'Reiseziele': '#6366F1',
  'Smarter Reisen': '#0EA5E9',
  'Grün Reisen': '#22C55E',
} as const;

const bgMap = {
  'Reisetipps': 'linear-gradient(135deg, #E0F2FE 0%, #BAE6FD 100%)',
  'KI & Reisen': 'linear-gradient(135deg, #FFF7ED 0%, #FFEDD5 100%)',
  'Fernweh': 'linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%)',
  'Unterwegs': 'linear-gradient(135deg, #F5F3FF 0%, #EDE9FE 100%)',
  'Clever Reisen': 'linear-gradient(135deg, #E0F2FE 0%, #BAE6FD 100%)',
  'Nur mit Handgepäck': 'linear-gradient(135deg, #FFFBEB 0%, #FEF3C7 100%)',
  'Traumunterkünfte': 'linear-gradient(135deg, #FDF2F8 0%, #FCE7F3 100%)',
  'Business Travel': 'linear-gradient(135deg, #F1F5F9 0%, #E2E8F0 100%)',
  'Nachhaltig': 'linear-gradient(135deg, #F0FDF4 0%, #DCFCE7 100%)',
  'Geheimtipps': 'linear-gradient(135deg, #FEF2F2 0%, #FEE2E2 100%)',
  'Reiseziele': 'linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%)',
  'Smarter Reisen': 'linear-gradient(135deg, #E0F2FE 0%, #BAE6FD 100%)',
  'Grün Reisen': 'linear-gradient(135deg, #F0FDF4 0%, #DCFCE7 100%)',
} as const;

const icons: Record<string, string> = {
  'Reisetipps': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4 20-7z"/><path d="M22 2 11 13"/></svg>`,
  'KI & Reisen': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/></svg>`,
  'Fernweh': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>`,
  'Unterwegs': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>`,
  'Clever Reisen': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>`,
  'Nur mit Handgepäck': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 20a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2Z"/><path d="M8 18V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v14"/><line x1="10" x2="10" y1="10" y2="14"/><line x1="14" x2="14" y1="10" y2="14"/></svg>`,
  'Traumunterkünfte': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>`,
  'Business Travel': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
  'Nachhaltig': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`,
  'Geheimtipps': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l4 6-10 13L2 9Z"/><path d="M11 3 8 9l4 13 4-13-3-6"/><line x1="2" x2="22" y1="9" y2="9"/></svg>`,
  'Reiseziele': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
  'Smarter Reisen': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>`,
  'Grün Reisen': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`,
};

type Cat = keyof typeof categoryColors;
const cat = post.data.category as Cat;
const color = categoryColors[cat] || '#0EA5E9';
const bg = bgMap[cat] || bgMap['Reisetipps'];
const icon = icons[cat] || icons['Reisetipps'];
const dateStr = post.data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });
const metaTitle = post.data.metaTitle || (post.data.title + ' | Zercy');
const canonicalUrl = `https://zercy.app/blog/${post.id}`;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-EX8PVPV4NW"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-EX8PVPV4NW');
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{metaTitle}</title>
  <meta name="description" content={post.data.description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={metaTitle} />
  <meta property="og:description" content={post.data.description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="article" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "url": canonicalUrl,
    "datePublished": post.data.pubDate.toISOString(),
    "dateModified": post.data.pubDate.toISOString(),
    "image": "https://zercy.app/og-image.png",
    "inLanguage": "de",
    "author": {
      "@type": "Person",
      "name": "Zercy",
      "url": "https://zercy.app/about"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Zercy",
      "url": "https://zercy.app",
      "logo": {
        "@type": "ImageObject",
        "url": "https://zercy.app/favicon-32.png"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": canonicalUrl
    }
  })}></script>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --navy: #0F172A; --blue: #0EA5E9; --orange: #F97316; --white: #FAFAF8; --slate: #475569; }
    body { font-family: 'Inter', sans-serif; background: var(--white); color: var(--navy); line-height: 1.7; }

    /* NAV */
    header { background: var(--white); border-bottom: 1px solid #E2E8F0; padding: 1rem 2rem; position: sticky; top: 0; z-index: 100; }
    .nav-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
    .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
    .logo-icon { font-size: 1.4rem; }
    .logo-text { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.3rem; color: var(--navy); }
    .nav-links { display: flex; align-items: center; gap: 1.5rem; font-size: 0.9rem; }
    .nav-links a { color: var(--slate); text-decoration: none; font-weight: 500; transition: color 0.2s; }
    .nav-links a:hover { color: var(--navy); }
    .nav-try { background: var(--orange); color: #fff !important; padding: 0.5rem 1.2rem; border-radius: 50px; font-weight: 700 !important; font-size: 0.85rem !important; }
    .nav-try:hover { opacity: 0.88; }
    .blog-lang-switch { display: flex; align-items: center; gap: 6px; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.04em; }
    .blog-lang { color: #94A3B8; text-decoration: none !important; transition: color 0.2s; }
    .blog-lang.active { color: var(--navy); }
    .blog-lang:hover { color: var(--blue); }
    .blog-lang-sep { color: #E2E8F0; }
    .btn-nav-pill { border-radius: 20px; padding: 5px 14px; font-size: 0.82rem; font-weight: 600; transition: all 0.15s; text-decoration: none !important; line-height: 1; }
    .btn-nav-blog { background: #F1F5F9; color: #64748B !important; }
    .btn-nav-blog:hover { background: #E2E8F0; color: var(--navy) !important; }
    .btn-nav-logbook { background: var(--blue); color: #fff !important; }
    .btn-nav-logbook:hover { opacity: 0.85; color: #fff !important; }

    /* BREADCRUMB */
    .breadcrumb { max-width: 760px; margin: 1.5rem auto 0; padding: 0 2rem; font-size: 0.85rem; color: #94A3B8; }
    .breadcrumb a { color: #94A3B8; text-decoration: none; }
    .breadcrumb a:hover { color: var(--blue); }

    /* HERO BANNER */
    .article-banner { height: 220px; display: flex; align-items: center; justify-content: center; margin: 1.5rem 0; }
    .cat-icon :global(svg) { width: 72px; height: 72px; display: block; }

    /* ARTICLE */
    main { max-width: 760px; margin: 0 auto; padding: 0 2rem 5rem; }
    .article-category { display: inline-block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.25rem 0.7rem; border-radius: 50px; margin-bottom: 1rem; color: #fff; }
    h1 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 2rem; font-weight: 800; line-height: 1.25; margin-bottom: 1rem; }
    .article-meta { font-size: 0.85rem; color: #94A3B8; margin-bottom: 2.5rem; display: flex; gap: 0.5rem; align-items: center; }
    .article-divider { border: none; border-top: 1px solid #E2E8F0; margin-bottom: 2.5rem; }

    /* PROSE */
    .prose h2 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.25rem; font-weight: 700; margin: 2.5rem 0 0.7rem; color: var(--navy); }
    .prose h3 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.05rem; font-weight: 700; margin: 1.8rem 0 0.5rem; color: var(--navy); }
    .prose p { color: #334155; margin-bottom: 1.1rem; font-size: 1.02rem; }
    .prose strong { color: var(--navy); }
    .prose a { color: var(--blue); text-decoration: underline; }
    .prose ul, .prose ol { margin: 0.5rem 0 1.2rem 1.4rem; color: #334155; }
    .prose li { margin-bottom: 0.4rem; }
    .prose hr { border: none; border-top: 1px solid #E2E8F0; margin: 2.5rem 0; }

    /* CTA BOX */
    .cta-box { background: linear-gradient(135deg, #0F172A 0%, #1e293b 100%); border-radius: 16px; padding: 2rem; margin-top: 3rem; text-align: center; }
    .cta-box p { color: rgba(255,255,255,0.7); margin-bottom: 1.2rem; font-size: 0.95rem; }
    .cta-box a { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--orange); color: #fff; padding: 0.8rem 1.8rem; border-radius: 50px; font-weight: 700; font-size: 0.95rem; text-decoration: none; transition: opacity 0.2s; }
    .cta-box a:hover { opacity: 0.88; text-decoration: none; }
    .cta-box h3 { font-family: 'Plus Jakarta Sans', sans-serif; color: #fff; font-size: 1.2rem; margin-bottom: 0.6rem; }

    /* BACK LINK */
    .back-link { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--blue); font-size: 0.88rem; font-weight: 600; text-decoration: none; margin-top: 2.5rem; }
    .back-link:hover { text-decoration: underline; }

    /* FOOTER */
    footer { background: var(--navy); border-top: 1px solid rgba(255,255,255,0.08); padding: 40px 0; }
    .footer-inner { max-width: 1100px; margin: 0 auto; padding: 0 24px; text-align: center; }
    .footer-logo { display: flex; align-items: center; gap: 8px; justify-content: center; margin-bottom: 10px; }
    .footer-logo span { color: #fff; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.3rem; }
    .footer-tagline { color: rgba(255,255,255,0.5); font-size: 0.9rem; margin-bottom: 8px; }
    .footer-links { margin-bottom: 8px; font-size: 0.82rem; }
    .footer-links a { color: rgba(255,255,255,0.4); text-decoration: none; }
    .footer-links a:hover { color: rgba(255,255,255,0.7); }
    .footer-copy { color: rgba(255,255,255,0.3); font-size: 0.8rem; }
  </style>
</head>
<body>
  <!-- BETA BANNER -->
  <div id="beta-banner" style="background:linear-gradient(90deg,#0EA5E9 0%,#F97316 100%);color:#fff;font-size:0.82rem;padding:0.55rem 3rem 0.55rem 1.2rem;text-align:center;position:relative;display:none;line-height:1.5;">
    Willkommen! Zercy ist gerade frisch gestartet. Du bist früh dabei. Falls etwas hakt, schreib uns: <a href="mailto:info@zercy.app" style="color:#fff;font-weight:700;text-decoration:underline">info@zercy.app</a>
    <button onclick="dismissBeta()" style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);background:none;border:none;color:rgba(255,255,255,0.8);cursor:pointer;font-size:1.2rem;line-height:1;padding:0.2rem 0.3rem">&times;</button>
  </div>
  <script>
    (function(){
      if(!localStorage.getItem('zercy_beta_ok')){
        document.getElementById('beta-banner').style.display='block';
      }
    })();
    function dismissBeta(){
      localStorage.setItem('zercy_beta_ok','1');
      document.getElementById('beta-banner').style.display='none';
    }
  </script>
  <header>
    <div class="nav-inner">
      <a href="/" class="logo">
        <span class="logo-icon">✈</span>
        <span class="logo-text">Zercy</span>
      </a>
      <nav class="nav-links">
        <a href="/blog" class="btn-nav-pill btn-nav-blog">Blog</a>
        <a href="/logbook" class="btn-nav-pill btn-nav-logbook" target="_blank" rel="noopener">Logbook</a>
        <div class="blog-lang-switch">
          <span class="blog-lang active">DE</span>
          <span class="blog-lang-sep">|</span>
          <a href="/en/blog" class="blog-lang">EN</a>
        </div>
        <a href="https://zercy.app" class="nav-try">Zercy.app</a>
      </nav>
    </div>
  </header>

  <div class="breadcrumb">
    <a href="/blog">← Blog</a> &nbsp;/&nbsp; {post.data.category}
  </div>

  <div class="article-banner" style={`background: ${bg};`}>
    <span class="cat-icon" style={`color: ${color};`}><Fragment set:html={icon} /></span>
  </div>

  <main>
    <span class="article-category" style={`background: ${color};`}>{post.data.category}</span>
    <h1>{post.data.title}</h1>
    <div class="article-meta">
      <span>{dateStr}</span>
      <span>·</span>
      <span>{post.data.readingTime} min Lesezeit</span>
    </div>
    <hr class="article-divider" />

    <div class="prose">
      <Content />
    </div>

    <div class="cta-box">
      <h3>Zercy ausprobieren</h3>
      <p>Kein Formular, kein Konto. Einfach deine Reiseidee eintippen — Zercy denkt mit.</p>
      <a href="https://zercy.app">✈ Kostenlos loslegen</a>
    </div>

    <a href="/blog" class="back-link">← Zurück zum Blog</a>
  </main>

  <footer>
    <div class="footer-inner">
      <div class="footer-logo"><span style="font-size:1.4rem">✈</span><span>Zercy</span></div>
      <p class="footer-tagline">Ob Reiseidee oder konkreter Plan — Zercy denkt mit.</p>
      <p class="footer-links"><a href="/about">About</a> &nbsp;·&nbsp; <a href="/blog">Blog</a> &nbsp;·&nbsp; <a href="/privacy">Privacy Policy</a> &nbsp;·&nbsp; <a href="/impressum">Impressum</a> &nbsp;·&nbsp; <a href="/terms">Terms</a> &nbsp;·&nbsp; <a href="mailto:info@zercy.app">info@zercy.app</a></p>
      <p class="footer-copy">© 2026 Zercy. Made with love and a lot of AI.</p>
    </div>
  </footer>
</body>
</html>
