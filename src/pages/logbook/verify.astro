<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Signing you in… — Zercy Logbook</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@800&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --navy: #0F172A; --blue: #0EA5E9; --orange: #F97316; --white: #FAFAF8; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--white);
      color: var(--navy);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .card { text-align: center; max-width: 360px; }
    .logo { display: flex; align-items: center; gap: 8px; justify-content: center; margin-bottom: 40px; }
    .logo-icon { font-size: 1.6rem; }
    .logo-text { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.4rem; color: var(--navy); }
    .spinner {
      width: 40px; height: 40px;
      border: 3px solid #E2E8F0;
      border-top-color: var(--orange);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 24px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    h1 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.25rem; font-weight: 800; margin-bottom: 8px; }
    p { color: #64748B; font-size: 0.9rem; }
    .error { color: #991B1B; background: #FEF2F2; border-radius: 12px; padding: 14px; margin-top: 16px; }
    a { color: var(--blue); }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <span class="logo-icon">✈</span>
      <span class="logo-text">Zercy</span>
    </div>

    <div id="loading">
      <div class="spinner"></div>
      <h1>Signing you in…</h1>
      <p>Just a moment.</p>
    </div>

    <div id="error-box" style="display:none">
      <h1>Link expired</h1>
      <div class="error" id="error-msg"></div>
      <p style="margin-top:20px"><a href="/logbook/login">Request a new sign-in link →</a></p>
    </div>
  </div>

  <script is:inline>
    // The actual verification happens server-side at /api/logbook-auth-verify
    // This page just shows a spinner while the redirect happens.
    // If somehow we end up here without being redirected, show a message.

    const token = new URLSearchParams(location.search).get('token');

    if (!token) {
      showError('No token found in the URL. Please request a new sign-in link.');
    } else {
      // Redirect to the verify API endpoint
      window.location.href = `/api/logbook-auth-verify?token=${encodeURIComponent(token)}`;
    }

    function showError(msg) {
      document.getElementById('loading').style.display = 'none';
      document.getElementById('error-box').style.display = 'block';
      document.getElementById('error-msg').textContent = msg;
    }

    // Fallback: if redirect takes too long, show an error
    setTimeout(() => {
      if (document.getElementById('loading').style.display !== 'none') {
        showError('Something went wrong. Please try again.');
      }
    }, 8000);
  </script>
</body>
</html>
