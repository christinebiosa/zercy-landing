    function t(key) { return STRINGS[currentLang]?.[key] ?? STRINGS.en[key] ?? key; }

    function setLang(lang) {
      currentLang = lang;
      localStorage.setItem('zlb-lang', lang);
      applyTranslations();
      // Re-render current trip view if active
      if (activeTrip) renderTripDetail(activeTrip, currentBookings);
      renderSidebar();
    }

    function applyTranslations() {
      document.querySelectorAll('[data-i18n]').forEach(el => {
        el.textContent = t(el.getAttribute('data-i18n'));
      });
      document.querySelectorAll('[data-i18n-ph]').forEach(el => {
        el.placeholder = t(el.getAttribute('data-i18n-ph'));
      });
      document.getElementById('lang-en')?.classList.toggle('active', currentLang === 'en');
      document.getElementById('lang-de')?.classList.toggle('active', currentLang === 'de');
      document.getElementById('btn-signout').textContent = t('signOut');
      document.querySelector('.logo-sub').textContent = t('logbook');
      const tip1 = document.getElementById('forward-tip1');
      const tip2 = document.getElementById('forward-tip2');
      const tip3 = document.getElementById('forward-tip3');
      if (tip1) tip1.innerHTML = t('forwardTip1');
      if (tip2) tip2.innerHTML = t('forwardTip2');
      if (tip3) tip3.innerHTML = t('forwardTip3');
    }

    const TRIP_EMOJIS = ['✈️','🏖️','🏔️','🌍','🗺️','🎒','🚂','🚗','🛳️','🏕️','🌴','🗼','🎡','🌊','🏙️','🌺'];

    const ICON_SVG = {
      flight: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21 4 19 4c-2 0-3 0-4.5 1.5l-3.5 3.5L3.2 6.2c-.5-.2-1-.1-1.4.3l-.6.6c-.4.4-.5 1-.1 1.4L7 12l-3.5 3.5-2 .5-.5 2.5 2.5-.5 3.5-3.5 3.9 5.9c.4.4 1 .5 1.4.1l.6-.6c.4-.4.5-.9.3-1.4z"/></svg>`,
      hotel: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>`,
      car: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>`,
      train: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="16" x="4" y="3" rx="2"/><path d="M4 11h16"/><path d="M12 3v8"/><path d="m8 19-2 3"/><path d="m18 22-2-3"/><path d="M8 15h.01"/><path d="M16 15h.01"/></svg>`,
      activity: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></svg>`,
      layover: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
      other: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/></svg>`
    };
    function iconSvg(type) { return ICON_SVG[type] || ICON_SVG.other; }
    function nodeClass(type) { return `tl-node tl-node-${type || 'other'}`; }

    // ── Init ────────────────────────────────────────────────────────────────
    async function init() {
      applyTranslations();

      // Check auth
      const res = await fetch('/api/logbook-trips', { credentials: 'include' }).catch(() => null);
      if (!res || res.status === 401) {
        window.location.href = '/logbook/login';
        return;
      }

      // Load user email from cookie hint (via API response header or just show generic)
      trips = await res.json();
      renderSidebar();
      if (trips.length > 0) selectTrip(trips[0]);
    }

    // ── Sidebar ──────────────────────────────────────────────────────────────
    function renderSidebar() {
      const list = document.getElementById('trip-list');
      if (trips.length === 0) {
        list.innerHTML = `<li class="empty-trips"><p>${t('noTrips')}</p></li>`;
        return;
      }
      list.innerHTML = trips.map(trip => `
        <li class="trip-item${activeTrip?.id === trip.id ? ' active' : ''}" onclick="selectTrip(${JSON.stringify(trip).replace(/"/g,'&quot;')})">
          <span class="trip-emoji">${trip.emoji || '✈️'}</span>
          <div class="trip-info">
            <div class="trip-name">${esc(trip.name)}</div>
            <div class="trip-meta">${trip.destination ? esc(trip.destination) : ''} ${trip.booking_count ? `· ${trip.booking_count} item${trip.booking_count>1?'s':''}` : ''}</div>
          </div>
          <span class="trip-status ${trip.status}">${trip.status}</span>
        </li>
      `).join('');
    }

    // ── Trip Selection ────────────────────────────────────────────────────────
    async function selectTrip(trip) {
      activeTrip = trip;
      renderSidebar();
      renderTripDetail(trip, null);
      const res = await fetch(`/api/logbook-bookings?trip_id=${trip.id}`, { credentials: 'include' });
      const bookings = await res.json();
      renderTripDetail(trip, bookings);
      startAutoRefresh();
    }

    function startAutoRefresh() {
      if (autoRefreshTimer) clearInterval(autoRefreshTimer);
      autoRefreshTimer = setInterval(refreshBookings, 30000);
    }

    async function refreshBookings() {
      if (!activeTrip) return;
      const btn = document.getElementById('refresh-btn');
      if (btn) btn.classList.add('spinning');
      const res = await fetch(`/api/logbook-bookings?trip_id=${activeTrip.id}`, { credentials: 'include' });
      if (res.ok) {
        const bookings = await res.json();
        currentBookings = bookings;
        const timeline = document.getElementById('bookings-timeline');
        if (timeline) timeline.innerHTML = renderBookings(bookings);
        await refreshTrips();
      }
      if (btn) btn.classList.remove('spinning');
    }

    function renderTripDetail(trip, bookings) {
      if (bookings !== null) currentBookings = bookings || [];
      const main = document.getElementById('main-area');
      document.getElementById('empty-state')?.remove();

      const datesStr = trip.start_date || trip.end_date
        ? [trip.start_date, trip.end_date].filter(Boolean).map(d => formatDate(d)).join(' → ')
        : t('noDatesSet');

      const counts = bookings ? {
        flights: bookings.filter(b => b.type === 'flight').length,
        hotels: bookings.filter(b => b.type === 'hotel').length,
        other: bookings.filter(b => !['flight','hotel'].includes(b.type)).length
      } : {};

      main.innerHTML = `
        <div class="trip-header">
          <div class="trip-header-left">
            <span class="trip-header-emoji">${trip.emoji || '✈️'}</span>
            <div class="trip-header-info">
              <h2>${esc(trip.name)}</h2>
              <div class="trip-dates">${trip.destination ? `<strong>${esc(trip.destination)}</strong> · ` : ''}${datesStr}</div>
            </div>
          </div>
          <div class="trip-header-actions">
            <button class="btn-outline" onclick="openEditTrip()">${t('edit')}</button>
            <button class="btn-primary" onclick="openBookingModal()">${t('addBooking')}</button>
          </div>
        </div>

        ${bookings ? `
        <div class="trip-stats">
          <div class="stat"><div class="stat-label">${t('flights')}</div><div class="stat-value">${counts.flights || 0}</div></div>
          <div class="stat"><div class="stat-label">${t('hotels')}</div><div class="stat-value">${counts.hotels || 0}</div></div>
          <div class="stat"><div class="stat-label">${t('other')}</div><div class="stat-value">${counts.other || 0}</div></div>
          <div class="stat"><div class="stat-label">${t('totalItems')}</div><div class="stat-value">${bookings.length}</div></div>
        </div>` : ''}

        <div class="bookings-section">
          <div class="bookings-header">
            <span class="bookings-title">${t('itinerary')}</span>
            <div style="display:flex;gap:8px;align-items:center">
              <button class="refresh-btn" id="refresh-btn" onclick="refreshBookings()"><span class="refresh-icon">↻</span> ${t('refresh')}</button>
              <button class="btn-primary" onclick="openBookingModal()">${t('addBooking')}</button>
            </div>
          </div>
          <div class="timeline" id="bookings-timeline">
            ${bookings === null ? `<div style="padding:16px;color:var(--muted)">Loading…</div>` : renderBookings(bookings)}
          </div>
        </div>
      `;
    }

    function renderBookings(bookings) {
      if (bookings.length === 0) return `
        <div style="border-radius:16px;border:1.5px dashed var(--border);overflow:hidden">
          <div class="welcome-state">
            <div class="big-icon">✈️</div>
            <h3>${t('welcomeTitle')}</h3>
            <p>${t('welcomeDesc')}</p>
          </div>
          <div style="padding:0 24px 32px">
            <div class="booking-options-grid">
              <div class="booking-option-card" onclick="openBookingModal('paste')">
                <div class="boc-icon">📋</div>
                <div class="boc-title">${t('optionPasteTitle')}</div>
                <div class="boc-desc">${t('optionPasteDesc')}</div>
                <div class="boc-cta">${t('optionPasteCta')}</div>
              </div>
              <div class="booking-option-card" onclick="openBookingModal('forward')">
                <div class="boc-icon">📧</div>
                <div class="boc-title">${t('optionForwardTitle')}</div>
                <div class="boc-desc">${t('optionForwardDesc')}</div>
                <div class="boc-cta">${t('optionForwardCta')}</div>
              </div>
              <div class="booking-option-card booking-option-card--soon">
                <div class="boc-icon">📨</div>
                <div class="boc-title">${t('optionGmailTitle')} <span class="soon-badge">${t('soonBadge')}</span></div>
                <div class="boc-desc">${t('optionGmailDesc')}</div>
                <div class="boc-cta" style="color:var(--muted)">${t('optionGmailCta')}</div>
              </div>
            </div>
          </div>
        </div>
      `;

      // Build flat list of timeline items
      const items = [];
      for (const b of bookings) {
        // ── NEW: use AI-generated timeline_entries when available ──
        const aiEntries = b.details?.timeline_entries;
        if (aiEntries && Array.isArray(aiEntries) && aiEntries.length > 0) {
          for (let i = 0; i < aiEntries.length; i++) {
            const e = aiEntries[i];
            const sortTime = (e.date && e.time) ? `${e.date}T${e.time}` : null;
            items.push({ kind: 'ai-entry', date: e.date || '__tbd__', time: sortTime, entry: e, booking: b, entryIdx: i, isFirst: i === 0 });
          }
          continue;
        }

        // ── FALLBACK: old logic for bookings without timeline_entries ──
        const segs = b.details?.segments;
        if (b.type === 'flight' && segs && segs.length > 0) {
          for (let i = 0; i < segs.length; i++) {
            const seg = segs[i];
            const depDate = seg.departure ? seg.departure.slice(0, 10) : (b.departure_at ? b.departure_at.slice(0, 10) : '__tbd__');
            items.push({ kind: 'segment', date: depDate, time: seg.departure || b.departure_at, seg, booking: b, isFirst: i === 0 });
            if (i < segs.length - 1 && seg.arrival && segs[i+1].departure) {
              const ms = new Date(segs[i+1].departure) - new Date(seg.arrival);
              if (ms > 0 && ms < 86400000) items.push({ kind: 'layover', date: seg.arrival.slice(0, 10), time: seg.arrival, ms, city: seg.to || '' });
            }
          }
        } else if (b.type === 'hotel') {
          const det = b.details || {};
          const checkinDate = b.departure_at ? b.departure_at.slice(0, 10) : '__tbd__';
          items.push({ kind: 'hotel-checkin', date: checkinDate, time: b.departure_at, booking: b });
          let coStr = b.arrival_at || det.check_out_date || det.checkout_date || det.checkout || det.check_out || det.end_date || null;
          if (!coStr && b.departure_at && det.nights) {
            const d = new Date(b.departure_at);
            d.setDate(d.getDate() + parseInt(det.nights));
            coStr = d.toISOString().slice(0, 10);
          }
          if (coStr) items.push({ kind: 'hotel-checkout', date: String(coStr).slice(0, 10), time: coStr, booking: b });
        } else {
          const date = b.departure_at ? b.departure_at.slice(0, 10) : '__tbd__';
          items.push({ kind: 'booking', date, time: b.departure_at, booking: b });
        }
      }

      // Sort by date then time
      items.sort((a, b) => {
        if (a.date === '__tbd__' && b.date === '__tbd__') return 0;
        if (a.date === '__tbd__') return 1;
        if (b.date === '__tbd__') return -1;
        if (a.date !== b.date) return a.date.localeCompare(b.date);
        const ta = a.time ? new Date(a.time).getTime() : Infinity;
        const tb = b.time ? new Date(b.time).getTime() : Infinity;
        return ta - tb;
      });

      // Group by date
      const groups = {};
      const groupOrder = [];
      for (const item of items) {
        if (!groups[item.date]) { groups[item.date] = []; groupOrder.push(item.date); }
        groups[item.date].push(item);
      }

      return groupOrder.map(key => {
        const header = key === '__tbd__'
          ? `<div class="tl-date-header">${t('dateTbd')}</div>`
          : `<div class="tl-date-header">${formatDayHeader(key)}</div>`;
        const entries = groups[key].map(item => {
          if (item.kind === 'ai-entry') return renderAiEntry(item.entry, item.booking.id, item.entryIdx, item.isFirst);
          if (item.kind === 'segment') return renderSegmentEntry(item);
          if (item.kind === 'layover') return renderLayoverEntry(item);
          if (item.kind === 'hotel-checkin') return renderHotelEntry(item, 'checkin');
          if (item.kind === 'hotel-checkout') return renderHotelEntry(item, 'checkout');
          return renderBookingEntry(item.booking);
        }).join('');
        return `<div class="tl-day">${header}<div class="tl-body">${entries}</div></div>`;
      }).join('');
    }

    // ── AI-driven entry renderer ─────────────────────────────────────────────
    function sublabelHtml(sublabel, icon, direction) {
      if (!sublabel) return '';
      const s = sublabel.toLowerCase();
      let badge = '';
      if (s.includes('check in') || s.includes('pick up')) {
        badge = '<span style="display:inline-block;background:#DCFCE7;color:#16A34A;border-radius:5px;padding:1px 7px;margin-right:7px;font-style:normal;font-weight:700;letter-spacing:0">→</span>';
      } else if (s.includes('check out') || s.includes('drop off')) {
        badge = '<span style="display:inline-block;background:#FEF3C7;color:#B45309;border-radius:5px;padding:1px 7px;margin-right:7px;font-style:normal;font-weight:700;letter-spacing:0">←</span>';
      } else if (icon === 'flight') {
        if (direction === 'return') {
          badge = '<span style="display:inline-block;background:#FEE2E2;color:#DC2626;border-radius:5px;padding:1px 7px;margin-right:7px;font-style:normal;font-weight:700;letter-spacing:0">↙</span>';
        } else {
          badge = '<span style="display:inline-block;background:#E0F2FE;color:#0284C7;border-radius:5px;padding:1px 7px;margin-right:7px;font-style:normal;font-weight:700;letter-spacing:0">↗</span>';
        }
      } else if (icon === 'train') {
        badge = '<span style="display:inline-block;background:#F3E8FF;color:#7C3AED;border-radius:5px;padding:1px 7px;margin-right:7px;font-style:normal;font-weight:700;letter-spacing:0">→</span>';
      }
      return `<div class="segment-detail" style="color:var(--muted);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px">${badge}${esc(sublabel)}</div>`;
    }

    function renderAiEntry(entry, bookingId, entryIdx, isFirst) {
      const icon = iconSvg(entry.icon);
      const timeStr = entry.time || '';

      if (entry.is_layover) {
        return `
          <div class="tl-entry">
            <div class="tl-meta">
              <span class="tl-time"></span>
              <div class="tl-node tl-node-clock">${iconSvg('layover')}</div>
            </div>
            <div class="layover-label">${esc(entry.label)}</div>
          </div>`;
      }

      const cardClass = 'segment-card tl-card-' + (entry.icon || 'other');
      return `
        <div class="tl-entry">
          <div class="tl-meta">
            <span class="tl-time">${esc(timeStr)}</span>
            <div class="${nodeClass(entry.icon)}">${icon}</div>
          </div>
          <div class="${cardClass}">
            ${isFirst ? `<button class="segment-delete" onclick="deleteBooking('${bookingId}')" title="Remove">✕</button>` : ''}
            <button class="segment-edit" onclick="openEditEntry('${bookingId}', ${entryIdx})" title="Edit">✏</button>
            <div class="segment-route">${esc(entry.label)}</div>
            ${sublabelHtml(entry.sublabel, entry.icon, entry.direction)}
            ${(entry.details || []).map(d => `<div class="segment-detail">${esc(d)}</div>`).join('')}
          </div>
        </div>`;
    }

    function renderSegmentEntry(item) {
      const { seg, booking, isFirst } = item;
      const timeStr = seg.departure ? formatTime(seg.departure) : '';
      const from = seg.from || seg.from_location || '';
      const to = seg.to || seg.to_location || '';
      const route = from && to ? `${esc(from)} → ${esc(to)}` : esc(from || to || 'Flight');
      const arrStr = seg.arrival ? formatDateTime(seg.arrival) : '';

      const details = [];
      if (seg.flight_number || seg.flightNumber) details.push(`Flight ${esc(seg.flight_number || seg.flightNumber)}`);
      if (booking.confirmation_code) details.push(`Confirmation ${esc(booking.confirmation_code)}`);
      if (seg.seat || seg.seats) details.push(`Seat(s) ${esc(seg.seat || seg.seats)}`);
      if (seg.terminal) details.push(`Terminal ${esc(seg.terminal)}`);
      if (seg.fare_class || seg.class) details.push(esc(seg.fare_class || seg.class));
      if (seg.baggage) details.push(`Baggage: ${esc(seg.baggage)}`);
      if (seg.duration) details.push(`Duration: ${esc(seg.duration)}`);
      if (arrStr) details.push(`Arrive ${arrStr}`);

      return `
        <div class="tl-entry">
          <div class="tl-meta">
            <span class="tl-time">${timeStr}</span>
            <div class="${nodeClass('flight')}">${iconSvg('flight')}</div>
          </div>
          <div class="segment-card tl-card-flight">
            ${isFirst ? `<button class="segment-delete" onclick="deleteBooking('${booking.id}')" title="Remove booking">✕</button>` : ''}
            <div class="segment-route">${route}</div>
            ${details.map(d => `<div class="segment-detail">${d}</div>`).join('')}
          </div>
        </div>`;
    }

    function renderLayoverEntry(item) {
      const h = Math.floor(item.ms / 3600000);
      const m = Math.floor((item.ms % 3600000) / 60000);
      const dur = h > 0 ? `${h}h ${m}m` : `${m} min`;
      return `
        <div class="tl-entry">
          <div class="tl-meta">
            <span class="tl-time"></span>
            <div class="tl-node tl-node-clock">${iconSvg('layover')}</div>
          </div>
          <div class="layover-label">${dur} layover in ${esc(item.city)}</div>
        </div>`;
    }

    function renderHotelEntry(item, mode) {
      const b = item.booking;
      const det = b.details || {};
      const isCheckin = mode === 'checkin';
      // Only show time if it's a real datetime (has T), not just a date
      const timeStr = item.time && String(item.time).includes('T') ? formatTime(item.time) : '';
      const platform = det.platform || null;
      const platformPrefix = platform ? `${esc(platform)}: ` : '';
      const hotelName = platformPrefix + esc(b.provider || det.name || 'Hotel');
      const label = isCheckin ? 'Check in' : 'Check out';
      const lines = [];
      if (det.address) lines.push(esc(det.address));
      if (isCheckin) {
        if (det.room_type) lines.push(esc(det.room_type));
        if (det.nights) lines.push(`${det.nights} night${det.nights>1?'s':''}`);
        if (det.guests) lines.push(`${det.guests} guest${det.guests>1?'s':''}`);
        if (det.price && det.currency) lines.push(`${det.price} ${det.currency}`);
      }
      if (b.confirmation_code) lines.push(`Confirmation ${esc(b.confirmation_code)}`);
      return `
        <div class="tl-entry">
          <div class="tl-meta">
            <span class="tl-time">${timeStr}</span>
            <div class="${nodeClass('hotel')}">${iconSvg('hotel')}</div>
          </div>
          <div class="segment-card tl-card-hotel">
            ${isCheckin ? `<button class="segment-delete" onclick="deleteBooking('${b.id}')" title="Remove">✕</button>` : ''}
            <div class="segment-route">${hotelName}</div>
            <div class="segment-detail" style="color:var(--muted);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px">${label}</div>
            ${lines.map(l => `<div class="segment-detail">${l}</div>`).join('')}
          </div>
        </div>`;
    }

    function renderBookingEntry(b) {
      const timeStr = b.departure_at ? formatTime(b.departure_at) : '';
      return `
        <div class="tl-entry">
          <div class="tl-meta">
            <span class="tl-time">${timeStr}</span>
            <div class="${nodeClass(b.type)}">${iconSvg(b.type)}</div>
          </div>
          ${renderBookingCard(b)}
        </div>`;
    }

    function formatDayHeader(dateStr) {
      const locale = currentLang === 'de' ? 'de-DE' : 'en-US';
      const dt = new Date(dateStr + 'T12:00:00');
      const weekday = dt.toLocaleDateString(locale, { weekday: 'long' }).toUpperCase();
      const day = dt.getDate();
      const month = dt.toLocaleDateString(locale, { month: 'long' }).toUpperCase();
      return `${weekday}, ${day} ${month} ${dt.getFullYear()}`;
    }

    function formatTime(d) {
      if (!d) return '';
      const dt = new Date(d);
      return dt.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
    }

    function renderBookingCard(b) {
      const icons = { flight:'✈️', hotel:'🏨', car:'🚗', train:'🚂', activity:'🎫', other:'📋' };
      const icon = icons[b.type] || '📋';
      const route = b.from_location && b.to_location ? `${esc(b.from_location)} → ${esc(b.to_location)}` : '';
      const dep = b.departure_at ? formatDateTime(b.departure_at) : '';
      const arr = b.arrival_at ? formatDateTime(b.arrival_at) : '';
      const datesStr = [dep, arr].filter(Boolean).join(' → ');

      const d = b.details || {};
      const chips = [];
      if (d.price && d.currency) chips.push(`${d.price} ${d.currency}`);
      if (d.class) chips.push(d.class);
      if (d.seat) chips.push(`Seat ${d.seat}`);
      if (d.flight_number) chips.push(d.flight_number);
      if (d.room_type) chips.push(d.room_type);
      if (d.nights) chips.push(`${d.nights} nights`);
      if (d.guests) chips.push(`${d.guests} guests`);
      if (d.car_type || d.car_model) chips.push(d.car_model || d.car_type);
      if (d.baggage) chips.push(d.baggage);
      if (d.passengers) chips.push(`${d.passengers} pax`);

      return `
        <div class="booking-card">
          <span class="booking-icon">${icon}</span>
          <div class="booking-body">
            <div class="booking-top">
              <span class="booking-provider">${esc(b.provider || capitalize(b.type))}</span>
              ${b.confirmation_code ? `<span class="booking-code">${esc(b.confirmation_code)}</span>` : ''}
            </div>
            ${route ? `<div class="booking-route">${route}</div>` : ''}
            ${datesStr ? `<div class="booking-dates">${datesStr}</div>` : ''}
            ${b.details?.summary || d.address ? `<div class="booking-summary">${esc(d.address || '')}</div>` : ''}
            ${chips.length ? `<div class="booking-details">${chips.map(c=>`<span class="detail-chip">${esc(c)}</span>`).join('')}</div>` : ''}
          </div>
          <button class="booking-delete" onclick="deleteBooking('${b.id}')" title="Remove">✕</button>
        </div>
      `;
    }

    // ── New/Edit Trip Modal ──────────────────────────────────────────────────
    function openNewTrip() {
      editingTripId = null;
      selectedEmoji = '✈️';
      document.getElementById('trip-modal-title').textContent = t('newTripTitle');
      document.getElementById('trip-save-btn').textContent = t('createTrip');
      document.getElementById('trip-name').value = '';
      document.getElementById('trip-destination').value = '';
      document.getElementById('trip-start').value = '';
      document.getElementById('trip-end').value = '';
      document.getElementById('trip-delete-zone').style.display = 'none';
      renderEmojiPicker();
      openOverlay('trip-modal');
      setTimeout(() => document.getElementById('trip-name').focus(), 100);
    }

    function openEditTrip() {
      if (!activeTrip) return;
      editingTripId = activeTrip.id;
      selectedEmoji = activeTrip.emoji || '✈️';
      document.getElementById('trip-modal-title').textContent = t('editTripTitle');
      document.getElementById('trip-save-btn').textContent = t('saveChanges');
      document.getElementById('trip-name').value = activeTrip.name;
      document.getElementById('trip-destination').value = activeTrip.destination || '';
      document.getElementById('trip-start').value = activeTrip.start_date || '';
      document.getElementById('trip-end').value = activeTrip.end_date || '';
      document.getElementById('trip-delete-zone').style.display = 'block';
      renderEmojiPicker();
      openOverlay('trip-modal');
    }

    async function deleteTripFromModal() {
      if (!confirm(t('confirmDeleteTrip'))) return;
      closeTripModal();
      await deleteTrip(editingTripId);
    }

    function renderEmojiPicker() {
      document.getElementById('emoji-picker').innerHTML = TRIP_EMOJIS.map(e => `
        <span class="emoji-option${selectedEmoji===e?' selected':''}" onclick="selectEmoji('${e}')">${e}</span>
      `).join('');
    }

    function selectEmoji(e) {
      selectedEmoji = e;
      renderEmojiPicker();
    }

    function closeTripModal() { closeOverlay('trip-modal'); }

    async function saveTrip() {
      const name = document.getElementById('trip-name').value.trim();
      if (!name) { showToast(t('toastTripRequired'), 'error'); return; }

      const btn = document.getElementById('trip-save-btn');
      btn.disabled = true;
      btn.innerHTML = '<span class="inline-spin"></span>';

      const body = {
        name,
        destination: document.getElementById('trip-destination').value.trim() || null,
        start_date: document.getElementById('trip-start').value || null,
        end_date: document.getElementById('trip-end').value || null,
        emoji: selectedEmoji
      };

      const url = editingTripId ? `/api/logbook-trips?id=${editingTripId}` : '/api/logbook-trips';
      const method = editingTripId ? 'PATCH' : 'POST';

      const res = await fetch(url, {
        method, credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });

      btn.disabled = false;

      if (res.ok) {
        closeTripModal();
        await refreshTrips();
        showToast(editingTripId ? t('toastTripUpdated') : t('toastTripCreated'), 'success');
      } else {
        btn.textContent = editingTripId ? t('saveChanges') : t('createTrip');
        showToast(t('toastError'), 'error');
      }
    }

    async function deleteTrip(id) {
      if (!confirm(t('confirmDeleteTrip'))) return;
      await fetch(`/api/logbook-trips?id=${id}`, { method: 'DELETE', credentials: 'include' });
      activeTrip = null;
      await refreshTrips();
      document.getElementById('main-area').innerHTML = `<div class="main-empty" id="empty-state">
        <div class="big-icon">🗺️</div>
        <h2>${t('noTrips')}</h2>
        <p>${currentLang === 'de' ? 'Erstelle deine erste Reise.' : 'Create your first trip to get started.'}</p>
        <button class="btn-primary" style="margin-top:20px" onclick="openNewTrip()">${t('newTrip')}</button>
      </div>`;
      showToast(t('toastTripDeleted'));
    }

    // ── Booking Modal ────────────────────────────────────────────────────────
    function openBookingModal(step = 'choose') {
      document.getElementById('booking-raw').value = '';
      document.getElementById('parse-result-box').innerHTML = '';
      parsedBooking = null;
      const btn = document.getElementById('parse-btn');
      btn.disabled = false;
      btn.textContent = t('parseBtn');
      showBookingStep(step);
      openOverlay('booking-modal');
    }

    function closeBookingModal() { closeOverlay('booking-modal'); }

    function showBookingStep(step) {
      ['choose', 'paste', 'forward', 'preview'].forEach(s => {
        const el = document.getElementById('booking-step-' + s);
        if (el) el.style.display = 'none';
      });
      const target = document.getElementById('booking-step-' + step);
      if (target) target.style.display = 'block';
      const titles = {
        choose: t('addABooking'),
        paste: t('pasteYourConf'),
        forward: t('forwardByEmail'),
        preview: t('reviewBooking')
      };
      document.getElementById('booking-modal-title').textContent = titles[step] || t('addABooking');
      if (step === 'paste') setTimeout(() => document.getElementById('booking-raw').focus(), 100);
    }

    function copyForwardAddress() {
      navigator.clipboard.writeText('plans@in.zercy.app').then(() => {
        showToast(t('toastCopied'), 'success');
      }).catch(() => {
        showToast('plans@in.zercy.app', '');
      });
    }

    function resetBookingModal() {
      document.getElementById('booking-raw').value = '';
      document.getElementById('parse-result-box').innerHTML = '';
      parsedBooking = null;
      const btn = document.getElementById('parse-btn');
      btn.disabled = false;
      btn.textContent = t('parseBtn');
      showBookingStep('paste');
    }

    async function parseBooking() {
      const raw = document.getElementById('booking-raw').value.trim();
      if (!raw) { showToast(t('toastPasteFirst'), 'error'); return; }

      const btn = document.getElementById('parse-btn');
      btn.disabled = true;
      btn.innerHTML = `<span class="inline-spin"></span> ${currentLang === 'de' ? 'Wird ausgelesen…' : 'Parsing…'}`;

      const tripContext = currentBookings.map(b => ({
        type: b.type,
        provider: b.provider || null,
        departure_at: b.departure_at || null,
        arrival_at: b.arrival_at || null,
        summary: b.details?.summary || null
      }));

      const res = await fetch('/api/logbook-parse', {
        method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ raw_text: raw, trip_context: tripContext })
      });

      btn.disabled = false;
      btn.textContent = t('parseBtn');

      const data = await res.json();

      showBookingStep('preview');

      if (res.ok && data.parsed) {
        parsedBooking = data.parsed;
        showParseResult(data.parsed);
      } else {
        parsedBooking = null;
        document.getElementById('confirm-save-btn').style.display = 'none';
        document.getElementById('parse-result-box').innerHTML = `
          <div class="parse-result error-state">
            <h4>${t('couldntRecognize')}</h4>
            <p class="parse-detail">${esc(data.error || 'Unknown error')}</p>
            <p class="parse-detail" style="margin-top:8px;color:#6B7280">${t('errorHint')}</p>
          </div>`;
      }
    }

    function showParseResult(parsed) {
      const icons = { flight:'✈️', hotel:'🏨', car:'🚗', train:'🚂', activity:'🎫', other:'📋' };
      const icon = icons[parsed.type] || '📋';
      const details = [];
      if (parsed.from_location && parsed.to_location) details.push(`${esc(parsed.from_location)} → ${esc(parsed.to_location)}`);
      if (parsed.departure_at) details.push(formatDateTime(parsed.departure_at));
      if (parsed.confirmation_code) details.push(`Ref: ${esc(parsed.confirmation_code)}`);
      if (parsed.details?.price) details.push(`${parsed.details.price} ${parsed.details.currency || ''}`);

      document.getElementById('parse-result-box').innerHTML = `
        <div class="parse-result">
          <h4>${t('bookingRecognized')}</h4>
          <div style="margin-top:8px">
            <span class="parse-type-badge">${icon} ${capitalize(parsed.type)}</span>
            ${parsed.provider ? `<strong style="margin-left:8px">${esc(parsed.provider)}</strong>` : ''}
          </div>
          ${parsed.summary ? `<div class="parse-detail" style="margin-top:8px;font-weight:500">${esc(parsed.summary)}</div>` : ''}
          ${details.length ? `<div class="parse-detail">${details.join(' · ')}</div>` : ''}
          ${parsed.trip_name_suggestion ? `<div class="parse-detail" style="margin-top:6px;color:var(--muted)">${t('suggestedTrip')} <em>${esc(parsed.trip_name_suggestion)}</em></div>` : ''}
        </div>
      `;
    }

    async function confirmBooking() {
      if (!parsedBooking || !activeTrip) return;
      const btn = document.getElementById('confirm-save-btn');
      btn.disabled = true;
      btn.innerHTML = '<span class="inline-spin"></span>';

      const raw = document.getElementById('booking-raw').value;
      const res = await fetch('/api/logbook-bookings', {
        method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ trip_id: activeTrip.id, parsed: parsedBooking, raw_text: raw })
      });

      btn.disabled = false;
      btn.textContent = t('saveToTrip');

      if (res.ok) {
        closeBookingModal();
        await selectTrip(activeTrip);
        await refreshTrips();
        showToast(t('toastBookingSaved'), 'success');
      } else {
        showToast(t('toastSaveFailed'), 'error');
      }
    }

    // ── Edit Entry ───────────────────────────────────────────────────────────
    function openEditEntry(bookingId, entryIdx) {
      const booking = currentBookings.find(b => b.id === bookingId);
      if (!booking || !booking.details?.timeline_entries) return;
      const entry = booking.details.timeline_entries[entryIdx];
      if (!entry) return;

      currentEditEntry = { bookingId, entryIdx };
      document.getElementById('edit-label').value = entry.label || '';
      document.getElementById('edit-time').value = entry.time || '';
      document.getElementById('edit-details').value = (entry.details || []).join('\n');

      const btn = document.getElementById('edit-save-btn');
      btn.disabled = false;
      btn.textContent = t('saveChanges');

      openOverlay('edit-entry-modal');
      setTimeout(() => document.getElementById('edit-label').focus(), 100);
    }

    function closeEditModal() {
      closeOverlay('edit-entry-modal');
      currentEditEntry = null;
    }

    async function saveEditEntry() {
      if (!currentEditEntry) return;
      const btn = document.getElementById('edit-save-btn');
      btn.disabled = true;
      btn.innerHTML = '<span class="inline-spin"></span>';

      const label = document.getElementById('edit-label').value.trim();
      const time = document.getElementById('edit-time').value.trim() || null;
      const details = document.getElementById('edit-details').value
        .split('\n').map(l => l.trim()).filter(Boolean);

      const res = await fetch(`/api/logbook-bookings?id=${currentEditEntry.bookingId}`, {
        method: 'PATCH', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ entry_index: currentEditEntry.entryIdx, entry_patch: { label, time, details } })
      });

      btn.disabled = false;
      btn.textContent = t('saveChanges');

      if (res.ok) {
        closeEditModal();
        await selectTrip(activeTrip);
        showToast(t('toastEntryUpdated'), 'success');
      } else {
        showToast(t('toastSaveFailed'), 'error');
      }
    }

    async function deleteBooking(id) {
      if (!confirm(t('confirmDeleteBooking'))) return;
      await fetch(`/api/logbook-bookings?id=${id}`, { method: 'DELETE', credentials: 'include' });
      await selectTrip(activeTrip);
      await refreshTrips();
      showToast(t('toastBookingRemoved'));
    }

    // ── Helpers ──────────────────────────────────────────────────────────────
    async function refreshTrips() {
      const res = await fetch('/api/logbook-trips', { credentials: 'include' });
      if (res.ok) {
        trips = await res.json();
        if (activeTrip) {
          activeTrip = trips.find(t => t.id === activeTrip.id) || null;
        }
        renderSidebar();
      }
    }

    // Beta banner
    (function(){
      if(!localStorage.getItem('zercy_beta_ok')){
        const b=document.getElementById('beta-banner');
        if(b) b.style.display='block';
      }
    })();
    function dismissBeta(){
      localStorage.setItem('zercy_beta_ok','1');
      const b=document.getElementById('beta-banner');
      if(b) b.style.display='none';
    }

    function logout() {
      // Cookie is HttpOnly — must be cleared server-side
      window.location.href = '/api/logbook-logout';
    }

    function openOverlay(id) { document.getElementById(id).classList.add('open'); }
    function closeOverlay(id) { document.getElementById(id).classList.remove('open'); }

    // Close modals on Escape
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        closeOverlay('trip-modal');
        closeOverlay('booking-modal');
        closeEditModal();
      }
    });
    // Close modals on overlay click
    ['trip-modal','booking-modal','edit-entry-modal'].forEach(id => {
      document.getElementById(id).addEventListener('click', function(e) {
        if (e.target === this) closeOverlay(id);
      });
    });

    function showToast(msg, type='') {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = `toast show${type ? ' '+type : ''}`;
      setTimeout(() => { t.className = 'toast'; }, 3000);
    }

    function esc(s) {
      if (!s) return '';
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function capitalize(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1) : ''; }
    function formatDate(d) {
      if (!d) return '';
      const dt = new Date(d + 'T00:00:00');
      return dt.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
    }
    function formatDateTime(d) {
      if (!d) return '';
      const dt = new Date(d);
      return dt.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
    }

    // ── Start ────────────────────────────────────────────────────────────────
    init();
  </script>
</body>
</html>
