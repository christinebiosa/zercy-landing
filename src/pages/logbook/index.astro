---
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Logbook — Zercy</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #0F172A;
      --blue: #0EA5E9;
      --orange: #F97316;
      --white: #FAFAF8;
      --muted: #64748B;
      --border: #E2E8F0;
      --card-bg: #fff;
      --surface: #F8FAFC;
    }
    body { font-family: 'Inter', sans-serif; background: var(--surface); color: var(--navy); min-height: 100vh; }

    /* ── Header ── */
    header {
      background: var(--navy);
      padding: 0 24px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky; top: 0; z-index: 100;
    }
    .logo { display: flex; align-items: center; gap: 8px; text-decoration: none; }
    .logo-icon { font-size: 1.3rem; }
    .logo-name { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.2rem; color: #fff; }
    .logo-sub { font-size: 0.7rem; color: rgba(255,255,255,0.4); margin-left: 6px; font-weight: 500; }
    .header-right { display: flex; align-items: center; gap: 12px; }
    .user-badge { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.7); border-radius: 20px; padding: 6px 12px; font-size: 0.8rem; }
    .logout-btn { background: none; border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.5); border-radius: 20px; padding: 5px 12px; font-size: 0.8rem; cursor: pointer; font-family: inherit; }
    .logout-btn:hover { border-color: rgba(255,255,255,0.4); color: rgba(255,255,255,0.8); }
    .header-nav-btn { border-radius: 20px; padding: 5px 13px; font-size: 0.8rem; font-weight: 600; text-decoration: none; transition: all 0.15s; line-height: 1; }
    .header-nav-blog { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.7) !important; }
    .header-nav-blog:hover { background: rgba(255,255,255,0.18); color: #fff !important; }
    .header-nav-app { background: var(--orange); color: #fff !important; }
    .header-nav-app:hover { opacity: 0.85; }

    /* ── Layout ── */
    .app { display: grid; grid-template-columns: 280px 1fr; min-height: calc(100vh - 60px); }
    @media (max-width: 768px) { .app { grid-template-columns: 1fr; } }

    /* ── Sidebar ── */
    .sidebar {
      background: var(--card-bg);
      border-right: 1px solid var(--border);
      padding: 20px 0;
      overflow-y: auto;
    }
    .sidebar-header { padding: 0 16px 16px; display: flex; align-items: center; justify-content: space-between; }
    .sidebar-title { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.85rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
    .new-trip-btn {
      background: var(--orange);
      color: #fff;
      border: none;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      transition: opacity 0.2s;
    }
    .new-trip-btn:hover { opacity: 0.85; }

    .trip-list { list-style: none; }
    .trip-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      cursor: pointer;
      border-left: 3px solid transparent;
      transition: all 0.15s;
    }
    .trip-item:hover { background: var(--surface); }
    .trip-item.active { background: #FFF7ED; border-left-color: var(--orange); }
    .trip-emoji { font-size: 1.3rem; flex-shrink: 0; }
    .trip-info { flex: 1; min-width: 0; }
    .trip-name { font-weight: 600; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .trip-meta { font-size: 0.75rem; color: var(--muted); margin-top: 1px; }
    .trip-status { font-size: 0.65rem; font-weight: 600; border-radius: 6px; padding: 2px 6px; margin-left: auto; flex-shrink: 0; }
    .trip-status.upcoming { background: #EFF6FF; color: #1E40AF; }
    .trip-status.active { background: #ECFDF5; color: #065F46; }
    .trip-status.past { background: #F1F5F9; color: #64748B; }

    .empty-trips { padding: 32px 16px; text-align: center; color: var(--muted); font-size: 0.9rem; }
    .empty-trips p { margin-bottom: 16px; }

    /* ── Main ── */
    .main { padding: 28px; overflow-y: auto; }

    .main-empty {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      min-height: 60vh; text-align: center;
      color: var(--muted);
    }
    .main-empty .big-icon { font-size: 3rem; margin-bottom: 16px; }
    .main-empty h2 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.1rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
    .main-empty p { font-size: 0.9rem; max-width: 300px; }

    /* ── Trip detail ── */
    .trip-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 24px; flex-wrap: wrap; gap: 12px; }
    .trip-header-left { display: flex; align-items: center; gap: 12px; }
    .trip-header-emoji { font-size: 2.4rem; }
    .trip-header-info h2 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.5rem; font-weight: 800; }
    .trip-header-info .trip-dates { color: var(--muted); font-size: 0.9rem; margin-top: 4px; }
    .trip-header-actions { display: flex; gap: 8px; }
    .btn-outline { background: none; border: 1.5px solid var(--border); color: var(--navy); border-radius: 20px; padding: 7px 14px; font-size: 0.85rem; font-weight: 500; cursor: pointer; font-family: inherit; transition: all 0.15s; }
    .btn-outline:hover { border-color: var(--navy); }
    .btn-primary { background: var(--orange); color: #fff; border: none; border-radius: 20px; padding: 8px 16px; font-size: 0.85rem; font-weight: 600; cursor: pointer; font-family: inherit; transition: opacity 0.2s; }
    .btn-primary:hover { opacity: 0.85; }
    .btn-danger { background: none; border: 1.5px solid #FECACA; color: #DC2626; border-radius: 20px; padding: 7px 14px; font-size: 0.85rem; font-weight: 500; cursor: pointer; font-family: inherit; }
    .btn-danger:hover { background: #FEF2F2; }
    .btn-delete-trip { background: #F1F5F9; border: none; color: #94A3B8; border-radius: 20px; padding: 8px 16px; font-size: 0.82rem; font-weight: 500; cursor: pointer; font-family: inherit; transition: all 0.15s; }
    .btn-delete-trip:hover { background: #FEE2E2; color: #DC2626; }

    /* ── Bookings timeline ── */
    .bookings-section { }
    .bookings-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .bookings-title { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.95rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; }

    .timeline { }

    /* ── TripIt-style day groups ── */
    .tl-day { margin-bottom: 24px; }

    .tl-date-header {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700;
      font-size: 0.78rem;
      color: #475569;
      background: #EEF2F7;
      border-radius: 8px;
      padding: 7px 14px 7px 72px;
      margin-bottom: 0;
    }

    .tl-body {
      position: relative;
      padding-top: 12px;
      padding-bottom: 8px;
    }

    /* Continuous vertical line through the day */
    .tl-body::before {
      content: '';
      position: absolute;
      left: 27px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: var(--border);
      z-index: 0;
    }

    .tl-entry {
      display: flex;
      gap: 16px;
      align-items: flex-start;
      margin-bottom: 10px;
      position: relative;
    }

    /* Line is now on .tl-body::before — no per-entry lines needed */
    .tl-entry::after { display: none; }

    .tl-meta {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 56px;
      flex-shrink: 0;
      padding-top: 4px;
    }

    .tl-time {
      font-size: 0.82rem;
      color: var(--navy);
      font-weight: 700;
      text-align: center;
      line-height: 1.2;
      margin-bottom: 6px;
      min-height: 18px;
    }

    .tl-node {
      width: 38px;
      height: 38px;
      background: var(--navy);
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 3px solid var(--surface);
      position: relative;
      z-index: 1;
      flex-shrink: 0;
    }
    .tl-node svg { width: 15px; height: 15px; flex-shrink: 0; }
    .tl-node-clock    { background: #E2E8F0; color: #64748B; }
    .tl-node-flight   { background: #F97316; }
    .tl-node-hotel    { background: #0EA5E9; }
    .tl-node-car      { background: #16A34A; }
    .tl-node-train    { background: #7C3AED; }
    .tl-node-activity { background: #D97706; }
    .tl-node-other    { background: #64748B; }

    /* ── Segment card (flight legs) ── */
    .segment-card {
      flex: 1;
      min-width: 0;
      max-width: 420px;
      padding: 10px 14px 12px;
      border-radius: 14px;
      background: #F8FAFC;
    }
    .tl-card-flight  { background: #FFF7ED; }
    .tl-card-hotel   { background: #EFF6FF; }
    .tl-card-car     { background: #F0FDF4; }
    .tl-card-train   { background: #F5F3FF; }
    .tl-card-activity { background: #FFFBEB; }
    .tl-card-other   { background: #F8FAFC; }
    .segment-route {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 1.05rem;
      color: var(--blue);
      margin-bottom: 8px;
    }
    .segment-detail {
      font-size: 0.85rem;
      color: #475569;
      margin-bottom: 3px;
      line-height: 1.5;
    }
    .segment-delete {
      float: right;
      background: none;
      border: none;
      color: #CBD5E1;
      cursor: pointer;
      font-size: 0.9rem;
      padding: 2px 4px;
      border-radius: 6px;
      margin-left: 4px;
    }
    .segment-delete:hover { color: #DC2626; }
    .segment-edit {
      float: right;
      background: none;
      border: none;
      color: #CBD5E1;
      cursor: pointer;
      font-size: 0.85rem;
      padding: 2px 4px;
      border-radius: 6px;
      margin-left: 4px;
    }
    .segment-edit:hover { color: var(--blue); background: #EFF6FF; }

    /* ── Layover entry ── */
    .layover-label {
      flex: 1;
      font-size: 0.85rem;
      color: var(--muted);
      font-style: italic;
      padding: 8px 0 14px;
      align-self: center;
    }

    /* ── Generic booking card (hotels, cars, etc.) ── */
    .booking-card {
      background: var(--card-bg);
      border-radius: 16px;
      padding: 14px 16px;
      display: flex;
      gap: 12px;
      align-items: flex-start;
      box-shadow: 0 1px 4px rgba(0,0,0,0.04);
      border: 1px solid var(--border);
      flex: 1;
      min-width: 0;
      position: relative;
    }
    .booking-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 2px; }
    .booking-body { flex: 1; min-width: 0; }
    .booking-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; }
    .booking-provider { font-weight: 700; font-size: 0.95rem; }
    .booking-code { font-size: 0.75rem; color: var(--muted); background: var(--surface); border-radius: 6px; padding: 2px 7px; font-family: monospace; flex-shrink: 0; }
    .booking-route { font-size: 0.9rem; color: var(--navy); margin-top: 4px; font-weight: 500; }
    .booking-dates { font-size: 0.8rem; color: var(--muted); margin-top: 4px; }
    .booking-summary { font-size: 0.85rem; color: #475569; margin-top: 6px; }
    .booking-details { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
    .detail-chip { background: var(--surface); border-radius: 6px; padding: 2px 8px; font-size: 0.75rem; color: #475569; }
    .booking-delete { background: none; border: none; color: #CBD5E1; cursor: pointer; font-size: 1rem; padding: 4px; border-radius: 6px; flex-shrink: 0; }
    .booking-delete:hover { color: #DC2626; background: #FEF2F2; }

    .no-bookings { background: var(--card-bg); border-radius: 16px; padding: 40px; text-align: center; border: 2px dashed var(--border); }
    .no-bookings .icon { font-size: 2rem; margin-bottom: 12px; }
    .no-bookings p { color: var(--muted); font-size: 0.9rem; }

    /* ── Loading ── */
    .skeleton { background: #E2E8F0; border-radius: 8px; animation: pulse 1.5s ease-in-out infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

    /* ── Modals ── */
    .overlay {
      position: fixed; inset: 0;
      background: rgba(15,23,42,0.5);
      z-index: 200;
      display: flex; align-items: center; justify-content: center;
      padding: 24px;
      opacity: 0; pointer-events: none;
      transition: opacity 0.2s;
    }
    .overlay.open { opacity: 1; pointer-events: all; }
    .modal {
      background: #fff;
      border-radius: 20px;
      padding: 32px;
      width: 100%;
      max-width: 520px;
      max-height: 90vh;
      overflow-y: auto;
      transform: translateY(20px);
      transition: transform 0.25s;
    }
    .overlay.open .modal { transform: translateY(0); }
    .modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
    .modal-title { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.2rem; font-weight: 800; }
    .modal-close { background: none; border: none; font-size: 1.4rem; cursor: pointer; color: var(--muted); line-height: 1; }
    .form-group { margin-bottom: 16px; }
    .form-label { display: block; font-weight: 600; font-size: 0.88rem; margin-bottom: 6px; }
    .form-input, .form-textarea, .form-select {
      width: 100%;
      padding: 10px 14px;
      border: 2px solid var(--border);
      border-radius: 10px;
      font-size: 0.95rem;
      font-family: inherit;
      transition: border-color 0.2s;
      outline: none;
      color: var(--navy);
      background: #fff;
    }
    .form-input:focus, .form-textarea:focus, .form-select:focus { border-color: var(--blue); }
    .form-textarea { resize: vertical; min-height: 140px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .form-hint { font-size: 0.78rem; color: var(--muted); margin-top: 5px; }
    .modal-actions { display: flex; gap: 10px; margin-top: 24px; justify-content: flex-end; }

    /* Parse result preview */
    .parse-result { background: #F0FDF4; border: 1.5px solid #86EFAC; border-radius: 14px; padding: 16px; margin-top: 16px; }
    .parse-result.error-state { background: #FEF2F2; border-color: #FECACA; }
    .parse-result h4 { font-weight: 700; font-size: 0.9rem; margin-bottom: 8px; color: #065F46; }
    .parse-result.error-state h4 { color: #991B1B; }
    .parse-type-badge { display: inline-flex; align-items: center; gap: 5px; background: #DCFCE7; border-radius: 8px; padding: 3px 10px; font-size: 0.82rem; font-weight: 600; color: #166534; }
    .parse-detail { font-size: 0.85rem; color: #374151; margin-top: 8px; }

    .emoji-picker { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 8px; }
    .emoji-option { font-size: 1.4rem; cursor: pointer; padding: 6px; border-radius: 8px; border: 2px solid transparent; transition: all 0.15s; }
    .emoji-option:hover { background: var(--surface); }
    .emoji-option.selected { border-color: var(--orange); background: #FFF7ED; }

    /* Toast */
    .toast {
      position: fixed; bottom: 24px; right: 24px; z-index: 300;
      background: var(--navy); color: #fff;
      border-radius: 12px; padding: 12px 18px;
      font-size: 0.9rem; font-weight: 500;
      transform: translateY(60px); opacity: 0;
      transition: all 0.3s;
      pointer-events: none;
    }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast.success { background: #065F46; }
    .toast.error { background: #991B1B; }

    /* Refresh button */
    .refresh-btn {
      background: none;
      border: 1.5px solid var(--border);
      color: var(--muted);
      border-radius: 20px;
      padding: 5px 12px;
      font-size: 0.8rem;
      font-weight: 500;
      cursor: pointer;
      font-family: inherit;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: all 0.15s;
    }
    .refresh-btn:hover { border-color: var(--navy); color: var(--navy); }
    .refresh-btn.spinning .refresh-icon { animation: spin 0.7s linear infinite; display: inline-block; }

    /* Spinner inline */
    .inline-spin {
      width: 16px; height: 16px;
      border: 2px solid rgba(255,255,255,0.4);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      display: inline-block;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Stats bar */
    .trip-stats { display: flex; gap: 20px; margin-bottom: 24px; }
    .stat { background: var(--card-bg); border-radius: 12px; padding: 14px 18px; flex: 1; border: 1px solid var(--border); }
    .stat-label { font-size: 0.75rem; color: var(--muted); font-weight: 500; margin-bottom: 4px; }
    .stat-value { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.2rem; font-weight: 700; }

    @media (max-width: 768px) {
      .app { grid-template-columns: 1fr; }
      .sidebar { border-right: none; border-bottom: 1px solid var(--border); max-height: 240px; }
      .main { padding: 16px; }
      .form-row { grid-template-columns: 1fr; }
      .trip-stats { flex-wrap: wrap; }
    }

    /* ── Booking option rows (modal) ── */
    .booking-option-row {
      display: flex; align-items: center; gap: 14px;
      padding: 14px 16px; border-radius: 14px;
      border: 1.5px solid var(--border); margin-bottom: 10px;
      cursor: pointer; transition: all 0.15s; background: #fff;
    }
    .booking-option-row:hover { border-color: var(--blue); background: #F0F9FF; }
    .booking-option-row--soon { opacity: 0.65; cursor: default; }
    .booking-option-row--soon:hover { border-color: var(--border); background: #fff; }
    .booking-option-icon {
      font-size: 1.5rem; width: 44px; height: 44px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      background: var(--surface); border-radius: 12px;
    }
    .booking-option-body { flex: 1; min-width: 0; }
    .booking-option-title { font-weight: 700; font-size: 0.92rem; color: var(--navy); display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .booking-option-desc { font-size: 0.8rem; color: var(--muted); margin-top: 2px; line-height: 1.4; }
    .booking-option-arrow { font-size: 1.4rem; color: #CBD5E1; flex-shrink: 0; line-height: 1; }
    .soon-badge { font-size: 0.68rem; font-weight: 700; background: #FEF3C7; color: #92400E; border-radius: 6px; padding: 2px 7px; }

    .back-btn {
      display: inline-flex; align-items: center; gap: 4px;
      background: none; border: none; color: var(--muted);
      font-size: 0.85rem; font-family: inherit; cursor: pointer;
      padding: 0; margin-bottom: 20px; font-weight: 500;
    }
    .back-btn:hover { color: var(--navy); }

    /* Forward email step */
    .forward-address-box {
      display: flex; align-items: center; justify-content: space-between;
      background: var(--surface); border: 1.5px solid var(--border);
      border-radius: 12px; padding: 13px 16px; margin-bottom: 16px; gap: 12px;
    }
    .forward-address-box span { font-family: monospace; font-size: 0.95rem; font-weight: 600; color: var(--blue); }
    .forward-address-box button {
      background: var(--blue); color: #fff; border: none;
      border-radius: 8px; padding: 6px 14px; font-size: 0.82rem; font-weight: 600;
      cursor: pointer; font-family: inherit; flex-shrink: 0; transition: opacity 0.2s;
    }
    .forward-address-box button:hover { opacity: 0.85; }
    .forward-tips { background: var(--surface); border-radius: 12px; padding: 14px 16px; margin-bottom: 20px; }
    .forward-tips p { font-size: 0.82rem; color: #374151; margin-bottom: 8px; line-height: 1.5; }
    .forward-tips p:last-child { margin-bottom: 0; }

    /* Empty state — 3 option cards */
    .welcome-state { text-align: center; padding: 40px 20px 28px; }
    .welcome-state .big-icon { font-size: 2.8rem; margin-bottom: 12px; }
    .welcome-state h3 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.15rem; font-weight: 800; color: var(--navy); margin-bottom: 8px; }
    .welcome-state p { font-size: 0.88rem; color: var(--muted); max-width: 400px; margin: 0 auto 28px; line-height: 1.6; }
    .booking-options-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; max-width: 640px; margin: 0 auto; }
    @media (max-width: 640px) { .booking-options-grid { grid-template-columns: 1fr; } }
    .booking-option-card {
      background: #fff; border: 1.5px solid var(--border); border-radius: 16px;
      padding: 20px 16px; text-align: left; cursor: pointer;
      transition: all 0.2s; display: flex; flex-direction: column; gap: 8px;
    }
    .booking-option-card:hover { border-color: var(--blue); box-shadow: 0 4px 16px rgba(14,165,233,0.1); transform: translateY(-2px); }
    .booking-option-card--soon { opacity: 0.6; cursor: default; }
    .booking-option-card--soon:hover { border-color: var(--border); box-shadow: none; transform: none; }
    .boc-icon { font-size: 1.8rem; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; background: var(--surface); border-radius: 12px; margin-bottom: 4px; }
    .boc-title { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.9rem; color: var(--navy); display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
    .boc-desc { font-size: 0.78rem; color: var(--muted); line-height: 1.5; }
    .boc-cta { font-size: 0.8rem; color: var(--blue); font-weight: 600; margin-top: auto; padding-top: 4px; }

    /* ── Language toggle ── */
    .lang-toggle { display: flex; align-items: center; gap: 2px; }
    .lang-btn { background: none; border: none; color: rgba(255,255,255,0.35); font-size: 0.75rem; font-weight: 700; cursor: pointer; font-family: inherit; padding: 4px 7px; border-radius: 6px; letter-spacing: 0.03em; transition: all 0.15s; }
    .lang-btn:hover { color: rgba(255,255,255,0.7); }
    .lang-btn.active { color: #fff; background: rgba(255,255,255,0.12); }
    .lang-sep { color: rgba(255,255,255,0.15); font-size: 0.7rem; }
  </style>
</head>
<body>

  <!-- BETA BANNER -->
  <div id="beta-banner" style="background:linear-gradient(90deg,#0EA5E9 0%,#F97316 100%);color:#fff;font-size:0.82rem;padding:0.55rem 3rem 0.55rem 1.2rem;text-align:center;position:relative;display:none;line-height:1.5;">
    Welcome! Zercy just launched. You&apos;re one of the first. If anything feels off, write us: <a href="mailto:info@zercy.app" style="color:#fff;font-weight:700;text-decoration:underline">info@zercy.app</a>
    <button onclick="dismissBeta()" style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);background:none;border:none;color:rgba(255,255,255,0.8);cursor:pointer;font-size:1.2rem;line-height:1;padding:0.2rem 0.3rem">&times;</button>
  </div>

  <!-- Header -->
  <header>
    <a href="/" class="logo">
      <span class="logo-icon">✈</span>
      <span class="logo-name">Zercy</span>
      <span class="logo-sub">Logbook</span>
    </a>
    <div class="header-right">
      <a href="/en/blog" target="_blank" rel="noopener" class="header-nav-btn header-nav-blog">Blog</a>
      <a href="https://zercy.app" target="_blank" rel="noopener" class="header-nav-btn header-nav-app">Zercy.app</a>
      <div class="lang-toggle">
        <button class="lang-btn active" id="lang-en" onclick="setLang('en')">EN</button>
        <span class="lang-sep">|</span>
        <button class="lang-btn" id="lang-de" onclick="setLang('de')">DE</button>
      </div>
      <span class="user-badge" id="user-email"></span>
      <button class="logout-btn" id="btn-signout" onclick="logout()">Sign out</button>
    </div>
  </header>

  <!-- App Grid -->
  <div class="app">

    <!-- Sidebar: trip list -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <span class="sidebar-title" data-i18n="myTrips">My Trips</span>
        <button class="new-trip-btn" onclick="openNewTrip()" data-i18n="newTrip">+ New trip</button>
      </div>
      <ul class="trip-list" id="trip-list">
        <li style="padding: 12px 16px; color: var(--muted); font-size: 0.85rem;">Loading…</li>
      </ul>
    </aside>

    <!-- Main: trip detail -->
    <main class="main" id="main-area">
      <div class="main-empty" id="empty-state">
        <div class="big-icon">🗺️</div>
        <h2>Your travel logbook</h2>
        <p>Create your first trip, then add flights, hotels, and more by pasting booking confirmations.</p>
        <button class="btn-primary" style="margin-top:20px" onclick="openNewTrip()">+ Create first trip</button>
      </div>
    </main>

  </div>

  <!-- Toast -->
  <div class="toast" id="toast"></div>

  <!-- ─── Modal: New / Edit Trip ─── -->
  <div class="overlay" id="trip-modal" onclick="e => { if(e.target===this) closeTripModal(); }">
    <div class="modal" onclick="event.stopPropagation()">
      <div class="modal-header">
        <span class="modal-title" id="trip-modal-title">New trip</span>
        <button class="modal-close" onclick="closeTripModal()">✕</button>
      </div>
      <div class="form-group">
        <label class="form-label" data-i18n="tripName">Trip name *</label>
        <input class="form-input" id="trip-name" placeholder="e.g. Japan Summer 2026" data-i18n-ph="tripNamePh" />
      </div>
      <div class="form-group">
        <label class="form-label" data-i18n="destination">Destination</label>
        <input class="form-input" id="trip-destination" placeholder="e.g. Tokyo, Kyoto" data-i18n-ph="destinationPh" />
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" data-i18n="startDate">Start date</label>
          <input class="form-input" id="trip-start" type="date" />
        </div>
        <div class="form-group">
          <label class="form-label" data-i18n="endDate">End date</label>
          <input class="form-input" id="trip-end" type="date" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" data-i18n="tripIcon">Trip icon</label>
        <div class="emoji-picker" id="emoji-picker"></div>
      </div>
      <div class="modal-actions">
        <button class="btn-outline" onclick="closeTripModal()" data-i18n="cancel">Cancel</button>
        <button class="btn-primary" id="trip-save-btn" onclick="saveTrip()">Create trip</button>
      </div>
      <div id="trip-delete-zone" style="display:none;margin-top:20px;padding-top:16px;border-top:1px solid var(--border);text-align:center">
        <button class="btn-delete-trip" onclick="deleteTripFromModal()" data-i18n="deleteTrip">Delete this trip and all its bookings</button>
      </div>
    </div>
  </div>

  <!-- ─── Modal: Add Booking ─── -->
  <div class="overlay" id="booking-modal" onclick="e => { if(e.target===this) closeBookingModal(); }">
    <div class="modal" onclick="event.stopPropagation()">
      <div class="modal-header">
        <span class="modal-title" id="booking-modal-title">Add a booking</span>
        <button class="modal-close" onclick="closeBookingModal()">✕</button>
      </div>

      <!-- Step 0: Choose method -->
      <div id="booking-step-choose">
        <p style="color:var(--muted);font-size:0.88rem;margin-bottom:18px" data-i18n="howToAdd">How do you want to add your booking?</p>
        <div class="booking-option-row" onclick="showBookingStep('paste')">
          <div class="booking-option-icon">📋</div>
          <div class="booking-option-body">
            <div class="booking-option-title" data-i18n="pasteModalTitle">Paste or type it in</div>
            <div class="booking-option-desc" data-i18n="pasteModalDesc">Copy your confirmation email and paste it — AI reads it instantly.</div>
          </div>
          <span class="booking-option-arrow">›</span>
        </div>
        <div class="booking-option-row" onclick="showBookingStep('forward')">
          <div class="booking-option-icon">📧</div>
          <div class="booking-option-body">
            <div class="booking-option-title" data-i18n="forwardModalTitle">Forward your email</div>
            <div class="booking-option-desc" data-i18n="forwardModalDesc">Send booking emails to plans@in.zercy.app — added to your logbook automatically.</div>
          </div>
          <span class="booking-option-arrow">›</span>
        </div>
        <div class="booking-option-row booking-option-row--soon">
          <div class="booking-option-icon">📨</div>
          <div class="booking-option-body">
            <div class="booking-option-title"><span data-i18n="gmailModalTitle">Connect Gmail</span> <span class="soon-badge" data-i18n="soonBadge">Coming soon</span></div>
            <div class="booking-option-desc" data-i18n="gmailModalDesc">Zercy automatically finds your travel emails. Nothing to forward, ever.</div>
          </div>
          <span class="booking-option-arrow" style="opacity:0.3">›</span>
        </div>
      </div>

      <!-- Step: Paste -->
      <div id="booking-step-paste" style="display:none">
        <button class="back-btn" onclick="showBookingStep('choose')" data-i18n="back">← Back</button>
        <div class="form-group">
          <textarea class="form-textarea" id="booking-raw" placeholder="Paste anything here:

• A booking confirmation email (flight, hotel, car rental, train, tour...)
• A restaurant reservation
• A manual note: &quot;Airbnb Barcelona, 3 nights, €320, check-in 14 Jul&quot;
• Any travel detail you want to remember

Zercy reads it like a human and extracts everything automatically." style="min-height:160px"></textarea>
        </div>
        <div class="modal-actions">
          <button class="btn-outline" onclick="closeBookingModal()" data-i18n="cancel">Cancel</button>
          <button class="btn-primary" id="parse-btn" onclick="parseBooking()" data-i18n="parseBtn">Parse with AI →</button>
        </div>
      </div>

      <!-- Step: Forward email -->
      <div id="booking-step-forward" style="display:none">
        <button class="back-btn" onclick="showBookingStep('choose')" data-i18n="back">← Back</button>
        <div style="text-align:center;padding:4px 0 20px">
          <div style="font-size:2.4rem;margin-bottom:10px">📧</div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1.05rem;font-weight:800;color:var(--navy);margin-bottom:6px" data-i18n="forwardTitle">Forward your booking emails</div>
          <div style="font-size:0.88rem;color:var(--muted)" data-i18n="forwardSubtitle">Just forward any confirmation email to this address:</div>
        </div>
        <div class="forward-address-box">
          <span id="forward-address-text">plans@in.zercy.app</span>
          <button onclick="copyForwardAddress()">Copy</button>
        </div>
        <div class="forward-tips" id="forward-tips">
          <p id="forward-tip1">💡 Save it as a contact: <strong>"Zercy Plans"</strong> — then you can forward with one tap on your phone.</p>
          <p id="forward-tip2">✅ Works with all booking types: flights, hotels, cars, tours, trains.</p>
          <p id="forward-tip3">⚡ Zercy parses the email automatically and adds it to your logbook within seconds.</p>
        </div>
        <div class="modal-actions">
          <button class="btn-primary" onclick="closeBookingModal()" data-i18n="gotIt">Got it!</button>
        </div>
      </div>

      <!-- Step: Preview -->
      <div id="booking-step-preview" style="display:none">
        <div id="parse-result-box"></div>
        <div class="modal-actions" style="margin-top:16px">
          <button class="btn-outline" onclick="showBookingStep('paste')" data-i18n="tryAgain">← Try again</button>
          <button class="btn-primary" id="confirm-save-btn" onclick="confirmBooking()" data-i18n="saveToTrip">Save to trip ✓</button>
        </div>
      </div>

    </div>
  </div>

  <!-- ─── Modal: Edit Entry ─── -->
  <div class="overlay" id="edit-entry-modal">
    <div class="modal" onclick="event.stopPropagation()">
      <div class="modal-header">
        <span class="modal-title" data-i18n="editEntry">Edit entry</span>
        <button class="modal-close" onclick="closeEditModal()">✕</button>
      </div>
      <div class="form-group">
        <label class="form-label" data-i18n="titleLabel">Title</label>
        <input class="form-input" id="edit-label" />
      </div>
      <div class="form-group">
        <label class="form-label"><span data-i18n="timeLabel">Time</span> <span style="font-weight:400;color:var(--muted)" data-i18n="timeHint">(24h, e.g. 16:00 — leave empty if unknown)</span></label>
        <input class="form-input" id="edit-time" placeholder="16:00" maxlength="5" />
      </div>
      <div class="form-group">
        <label class="form-label"><span data-i18n="detailsLabel">Details</span> <span style="font-weight:400;color:var(--muted)" data-i18n="detailsHint">(one line per item)</span></label>
        <textarea class="form-textarea" id="edit-details" style="min-height:130px"></textarea>
      </div>
      <div class="modal-actions">
        <button class="btn-outline" onclick="closeEditModal()" data-i18n="cancel">Cancel</button>
        <button class="btn-primary" id="edit-save-btn" onclick="saveEditEntry()" data-i18n="saveChanges">Save changes</button>
      </div>
    </div>
  </div>

  <!-- ─── Main Script ─── -->
  <script is:inline>
    // ── State ────────────────────────────────────────────────────────────────
    let trips = [];
    let activeTrip = null;
    let currentBookings = [];
    let parsedBooking = null;
    let currentEditEntry = null;
    let editingTripId = null;
    let selectedEmoji = '✈️';
