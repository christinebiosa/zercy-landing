---
import { getCollection } from 'astro:content';
import BlogSearch from '../../../components/BlogSearch.astro';
import NewsletterSignup from '../../../components/NewsletterSignup.astro';

// No PIN for ES launch — sort all by date desc.
const posts = (await getCollection('bloges')).sort((a, b) => {
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

const categoryColors = {
  'Consejos de viaje': '#0EA5E9',
  'IA y viajes': '#F97316',
  'Lugares lejanos': '#10B981',
  'En camino': '#8B5CF6',
  'Viaje inteligente': '#0EA5E9',
  'Solo equipaje de mano': '#F59E0B',
  'Dónde alojarse': '#EC4899',
  'Viajes de negocios': '#0F172A',
  'Viaje sostenible': '#22C55E',
  'Joyas ocultas': '#EF4444',
} as const;

const categoryBg = {
  'Consejos de viaje': 'linear-gradient(135deg, #E0F2FE 0%, #BAE6FD 100%)',
  'IA y viajes': 'linear-gradient(135deg, #FFF7ED 0%, #FFEDD5 100%)',
  'Lugares lejanos': 'linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%)',
  'En camino': 'linear-gradient(135deg, #F5F3FF 0%, #EDE9FE 100%)',
  'Viaje inteligente': 'linear-gradient(135deg, #E0F2FE 0%, #BAE6FD 100%)',
  'Solo equipaje de mano': 'linear-gradient(135deg, #FFFBEB 0%, #FEF3C7 100%)',
  'Dónde alojarse': 'linear-gradient(135deg, #FDF2F8 0%, #FCE7F3 100%)',
  'Viajes de negocios': 'linear-gradient(135deg, #F1F5F9 0%, #E2E8F0 100%)',
  'Viaje sostenible': 'linear-gradient(135deg, #F0FDF4 0%, #DCFCE7 100%)',
  'Joyas ocultas': 'linear-gradient(135deg, #FEF2F2 0%, #FEE2E2 100%)',
} as const;

const categoryIcons: Record<string, string> = {
  'Consejos de viaje': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4 20-7z"/><path d="M22 2 11 13"/></svg>`,
  'IA y viajes': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/></svg>`,
  'Lugares lejanos': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>`,
  'En camino': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>`,
  'Viaje inteligente': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>`,
  'Solo equipaje de mano': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 20a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2Z"/><path d="M8 18V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v14"/><line x1="10" x2="10" y1="10" y2="14"/><line x1="14" x2="14" y1="10" y2="14"/></svg>`,
  'Dónde alojarse': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>`,
  'Viajes de negocios': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
  'Viaje sostenible': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`,
  'Joyas ocultas': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l4 6-10 13L2 9Z"/><path d="M11 3 8 9l4 13 4-13-3-6"/><line x1="2" x2="22" y1="9" y2="9"/></svg>`,
};

type Cat = keyof typeof categoryColors;

const categoryOrder = ['Dónde alojarse', 'En camino', 'Consejos de viaje', 'Lugares lejanos', 'Viaje inteligente', 'IA y viajes', 'Solo equipaje de mano', 'Joyas ocultas', 'Viaje sostenible', 'Viajes de negocios'];
const existingCats = new Set(posts.map(p => p.data.category));
const categories = categoryOrder.filter(c => existingCats.has(c));

const destinationPosts = [...posts]
  .filter(p => p.id.startsWith('donde-alojarse-') && p.data.heroImage)
  .sort((a, b) => {
    const nameA = a.data.title.match(/mejores hoteles (?:en|de) (.+?):/i)?.[1] ?? a.data.title;
    const nameB = b.data.title.match(/mejores hoteles (?:en|de) (.+?):/i)?.[1] ?? b.data.title;
    return nameA.localeCompare(nameB, 'es');
  });
---
<!DOCTYPE html>
<html lang="es">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-EX8PVPV4NW"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-EX8PVPV4NW');
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zercy Blog: Consejos de Viaje e IA</title>
  <meta name="description" content="Consejos de viaje, estrategias de reserva y todo sobre planificación de viajes con IA. El blog de Zercy para viajeros que quieren reservar mejor." />
  <link rel="canonical" href="https://www.zercy.app/es/blog/" />
  <meta property="og:title" content="Zercy Blog: Consejos de Viaje e IA" />
  <meta property="og:description" content="Consejos de viaje, estrategias de reserva y todo sobre planificación de viajes con IA." />
  <meta property="og:url" content="https://www.zercy.app/es/blog/" />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --navy: #0F172A; --blue: #0EA5E9; --orange: #F97316; --white: #FAFAF8; --slate: #475569; }
    body { font-family: 'Inter', sans-serif; background: var(--white); color: var(--navy); line-height: 1.7; }
    header { background: var(--white); border-bottom: 1px solid #E2E8F0; padding: 1rem 2rem; position: sticky; top: 0; z-index: 100; }
    .nav-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
    .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
    .logo-icon { font-size: 1.4rem; }
    .logo-text { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.3rem; color: var(--navy); }
    .nav-links { display: flex; align-items: center; gap: 1.5rem; font-size: 0.9rem; }
    .nav-links a { color: var(--slate); text-decoration: none; font-weight: 500; transition: color 0.2s; }
    .nav-links a:hover { color: var(--navy); }
    .nav-links a.active { color: var(--navy); font-weight: 700; }
    .nav-try { background: var(--orange); color: #fff !important; padding: 0.5rem 1.2rem; border-radius: 50px; font-weight: 700 !important; font-size: 0.85rem !important; }
    .nav-try:hover { opacity: 0.88; }
    .btn-nav-pill { border-radius: 20px; padding: 5px 14px; font-size: 0.82rem; font-weight: 600; transition: all 0.15s; text-decoration: none !important; line-height: 1; }
    .btn-nav-blog { background: #F97316; color: #fff !important; }
    .btn-nav-blog:hover { background: #EA6C0A; color: #fff !important; }
    .btn-nav-logbook { background: var(--blue); color: #fff !important; }
    .btn-nav-logbook:hover { opacity: 0.85; color: #fff !important; }
    .blog-lang-switch { display: flex; align-items: center; gap: 6px; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.04em; }
    .blog-lang { color: #94A3B8; text-decoration: none !important; transition: color 0.2s; }
    .blog-lang.active { color: var(--navy); }
    .blog-lang:hover { color: var(--blue); }
    .blog-lang-sep { color: #E2E8F0; }
    .blog-hero { max-width: 760px; margin: 0 auto; padding: 3.5rem 2rem 1rem; }
    .blog-hero h1 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 2.4rem; font-weight: 800; margin-bottom: 0.6rem; }
    .blog-hero p { color: var(--slate); font-size: 1.05rem; }
    .blog-grid { max-width: 1100px; margin: 2.5rem auto 5rem; padding: 0 2rem; display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; }
    @media (max-width: 680px) { .blog-grid { grid-template-columns: 1fr; } }
    .card { background: #fff; border: 1px solid #E2E8F0; border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; transition: box-shadow 0.2s, transform 0.2s; text-decoration: none; color: inherit; }
    .card:hover { box-shadow: 0 8px 32px rgba(15,23,42,0.1); transform: translateY(-3px); }
    .card-image { height: 110px; display: flex; align-items: center; justify-content: center; }
    .card-image-photo { height: 180px; background-size: cover; background-position: center; background-repeat: no-repeat; }
    .cat-icon :global(svg) { width: 38px; height: 38px; display: block; }
    .card-body { padding: 1.4rem 1.5rem 1.5rem; flex: 1; display: flex; flex-direction: column; }
    .card-category { display: inline-block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.25rem 0.7rem; border-radius: 50px; margin-bottom: 0.8rem; color: #fff; }
    .card-title { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.15rem; font-weight: 700; margin-bottom: 0.6rem; line-height: 1.4; }
    .card-excerpt { color: #475569; font-size: 0.9rem; line-height: 1.6; flex: 1; margin-bottom: 1.2rem; }
    .card-meta { font-size: 0.8rem; color: #94A3B8; display: flex; align-items: center; gap: 0.5rem; }
    .card-read { margin-top: 1rem; font-size: 0.85rem; font-weight: 600; color: var(--blue); }
    .chips-bar { max-width: 1100px; margin: 0 auto 0; padding: 1.5rem 2rem 0; display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; }
    .chip { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.4rem 1rem; border-radius: 50px; border: 1.5px solid #E2E8F0; background: #fff; font-size: 0.82rem; font-weight: 600; cursor: pointer; transition: all 0.18s; color: var(--slate); font-family: 'Inter', sans-serif; white-space: nowrap; }
    .chip:hover { border-color: #94A3B8; color: var(--navy); }
    .chip.active { background: var(--navy); border-color: var(--navy); color: #fff; }
    .chip .chip-icon { display: inline-flex; align-items: center; }
    .chip-icon :global(svg) { width: 14px; height: 14px; display: block; }
    .card.hidden { display: none; }
    footer { background: var(--navy); border-top: 1px solid rgba(255,255,255,0.08); padding: 40px 0; }
    .footer-inner { max-width: 1100px; margin: 0 auto; padding: 0 24px; text-align: center; }
    /* CITY FINDER */
    .city-finder { max-width: 1100px; margin: 1.75rem auto 0; padding: 0 2rem; }
    .city-finder-toggle { display: inline-flex; align-items: center; gap: 0.55rem; background: #fff; border: 1.5px solid #E2E8F0; border-radius: 50px; padding: 0.42rem 1rem 0.42rem 0.75rem; cursor: pointer; font-family: 'Inter', sans-serif; font-size: 0.83rem; font-weight: 600; color: var(--slate); transition: all 0.18s; }
    .city-finder-toggle:hover { border-color: #CBD5E1; color: var(--navy); }
    .city-finder-toggle.open { border-color: #EC4899; color: #EC4899; background: #FDF2F8; }
    .city-finder-icon { display: flex; align-items: center; color: #EC4899; }
    .city-finder-icon svg { width: 14px; height: 14px; }
    .city-count-pill { background: #EC4899; color: #fff; font-size: 0.67rem; font-weight: 700; padding: 0.15rem 0.55rem; border-radius: 50px; letter-spacing: 0.04em; white-space: nowrap; }
    .city-finder-chevron { font-size: 0.7rem; color: #94A3B8; margin-left: 0.1rem; display: inline-block; transition: transform 0.2s; }
    .city-finder-toggle.open .city-finder-chevron { transform: rotate(180deg); }
    .city-finder-panel { display: none; margin-top: 0.6rem; padding: 1rem 1.25rem; background: #fff; border: 1.5px solid #E2E8F0; border-radius: 12px; columns: 5; column-gap: 0; }
    .city-finder-panel.open { display: block; }
    @media (max-width: 900px) { .city-finder-panel { columns: 4; } }
    @media (max-width: 640px) { .city-finder-panel { columns: 3; } }
    @media (max-width: 400px) { .city-finder-panel { columns: 2; } }
    .city-link { display: flex; align-items: center; gap: 0.4rem; font-size: 0.81rem; font-weight: 500; color: var(--slate); text-decoration: none; padding: 0.22rem 0; break-inside: avoid; transition: color 0.15s; }
    .city-link::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: #EC4899; flex-shrink: 0; opacity: 0.65; }
    .city-link:hover { color: var(--navy); }
    .city-link:hover::before { opacity: 1; }
    .city-finder.hidden { display: none; }
    .footer-logo { display: flex; align-items: center; gap: 8px; justify-content: center; margin-bottom: 10px; }
    .footer-logo span { color: #fff; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.3rem; }
    .footer-tagline { color: rgba(255,255,255,0.5); font-size: 0.9rem; margin-bottom: 8px; }
    .footer-links { margin-bottom: 8px; font-size: 0.82rem; }
    .footer-links a { color: rgba(255,255,255,0.4); text-decoration: none; }
    .footer-links a:hover { color: rgba(255,255,255,0.7); }
    .footer-copy { color: rgba(255,255,255,0.3); font-size: 0.8rem; }
  </style>
</head>
<body>
  <!-- BETA BANNER -->
  <div id="beta-banner" style="background:linear-gradient(90deg,#0EA5E9 0%,#F97316 100%);color:#fff;font-size:0.82rem;padding:0.55rem 3rem 0.55rem 1.2rem;text-align:center;position:relative;display:none;line-height:1.5;">
    ¡Bienvenido! Zercy acaba de lanzarse. Eres uno de los primeros. Si algo te falla, escríbenos: <a href="mailto:info@zercy.app" style="color:#fff;font-weight:700;text-decoration:underline">info@zercy.app</a>
    <button onclick="dismissBeta()" style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);background:none;border:none;color:rgba(255,255,255,0.8);cursor:pointer;font-size:1.2rem;line-height:1;padding:0.2rem 0.3rem">&times;</button>
  </div>
  <script>
    (function(){
      if(!localStorage.getItem('zercy_beta_ok')){
        document.getElementById('beta-banner').style.display='block';
      }
    })();
    function dismissBeta(){
      localStorage.setItem('zercy_beta_ok','1');
      document.getElementById('beta-banner').style.display='none';
    }
  </script>
  <header>
    <div class="nav-inner">
      <a href="/es" class="logo">
        <span class="logo-icon">✈</span>
        <span class="logo-text">Zercy</span>
      </a>
      <nav class="nav-links">
        <a href="/es/blog" class="btn-nav-pill btn-nav-blog">Blog</a>
        <a href="/logbook" class="btn-nav-pill btn-nav-logbook" target="_blank" rel="noopener">Logbook</a>
        <div class="blog-lang-switch">
          <a href="/en/blog" class="blog-lang">EN</a>
          <span class="blog-lang-sep">|</span>
          <span class="blog-lang active">ES</span>
          <span class="blog-lang-sep">|</span>
          <a href="/blog" class="blog-lang">DE</a>
        </div>
        <a href="https://zercy.app" class="nav-try">Zercy.app</a>
      </nav>
    </div>
  </header>

  <div class="blog-hero">
    <h1>Blog</h1>
    <p>Consejos de viaje, estrategias de reserva y todo sobre planificación inteligente de viajes.</p>
  </div>

  <BlogSearch lang="es" pathPrefix="/es/blog/" />

  <div class="city-finder" id="city-finder">
    <button class="city-finder-toggle" id="city-finder-toggle" aria-expanded="false">
      <span class="city-finder-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/></svg></span>
      Guías de ciudad
      <span class="city-count-pill">{destinationPosts.length} ciudades</span>
      <span class="city-finder-chevron">▾</span>
    </button>
    <div class="city-finder-panel" id="city-finder-panel">
      {destinationPosts.map(post => {
        const cityName = post.data.title.match(/mejores hoteles (?:en|de) (.+?):/i)?.[1] ?? '';
        return <a href={`/es/blog/${post.id}`} class="city-link">{cityName}</a>;
      })}
    </div>
  </div>

  <div class="chips-bar">
    <button class="chip active" data-filter="all">Todos</button>
    {categories.map((cat) => {
      const chipIcon = categoryIcons[cat] || categoryIcons['Consejos de viaje'];
      return <button class="chip" data-filter={cat}><span class="chip-icon"><Fragment set:html={chipIcon} /></span>{cat}</button>;
    })}
  </div>

  <NewsletterSignup lang="es" />

  <div class="blog-grid">
    {posts.map((post) => {
      const cat = post.data.category as Cat;
      const color = categoryColors[cat] || '#0EA5E9';
      const bg = categoryBg[cat] || 'linear-gradient(135deg, #E0F2FE 0%, #BAE6FD 100%)';
      const icon = categoryIcons[cat] || categoryIcons['Consejos de viaje'];
      const dateStr = post.data.pubDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
      return (
        <a href={`/es/blog/${post.id}`} class="card" data-category={post.data.category}>
          {post.data.heroImage ? (
            <div class="card-image-photo" style={`background-image: url('${post.data.heroImage}');`}></div>
          ) : (
            <div class="card-image" style={`background: ${bg};`}>
              <span class="cat-icon" style={`color: ${color};`}><Fragment set:html={icon} /></span>
            </div>
          )}
          <div class="card-body">
            <span class="card-category" style={`background: ${color};`}>{post.data.category}</span>
            <div class="card-title">{post.data.title}</div>
            <div class="card-excerpt">{post.data.description}</div>
            <div class="card-meta">
              <span>{dateStr}</span>
              <span>·</span>
              <span>{post.data.readingTime} min de lectura</span>
            </div>
            <div class="card-read">Leer →</div>
          </div>
        </a>
      );
    })}
  </div>

  <script>
    const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
    const cards = document.querySelectorAll<HTMLElement>('.card');
    const cityFinder = document.getElementById('city-finder');

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        const filter = chip.dataset.filter;
        chips.forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        cards.forEach(card => {
          if (filter === 'all' || card.dataset.category === filter) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });
        if (cityFinder) {
          if (filter === 'all' || filter === 'Dónde alojarse') {
            cityFinder.classList.remove('hidden');
          } else {
            cityFinder.classList.add('hidden');
          }
        }
      });
    });

    const toggleBtn = document.getElementById('city-finder-toggle') as HTMLButtonElement | null;
    const panel = document.getElementById('city-finder-panel');
    if (toggleBtn && panel) {
      toggleBtn.addEventListener('click', () => {
        const isOpen = panel.classList.toggle('open');
        toggleBtn.classList.toggle('open', isOpen);
        toggleBtn.setAttribute('aria-expanded', String(isOpen));
      });
    }
  </script>

