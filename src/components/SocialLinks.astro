<style>
  .footer-social { display: flex; justify-content: center; gap: 14px; margin: 4px 0 18px; flex-wrap: wrap; }
  .footer-social .social-icon { display: inline-flex; align-items: center; justify-content: center; width: 42px; height: 42px; border-radius: 50%; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); color: rgba(255,255,255,0.7); transition: transform 0.25s ease, background 0.3s ease, color 0.25s ease, box-shadow 0.3s ease, border-color 0.3s ease; }
  .footer-social .social-icon svg { width: 19px; height: 19px; }
  .footer-social .social-icon:hover, .footer-social .social-icon:focus-visible { transform: translateY(-3px); color: #fff; outline: none; }
  .footer-social .social-ig:hover, .footer-social .social-ig:focus-visible { background: linear-gradient(45deg, #feda75, #fa7e1e, #d62976, #962fbf, #4f5bd5); border-color: transparent; box-shadow: 0 7px 20px rgba(214,41,118,0.45); }
  .footer-social .social-tt:hover, .footer-social .social-tt:focus-visible { background: #010101; border-color: rgba(37,244,238,0.55); box-shadow: 0 7px 20px rgba(37,244,238,0.3), inset 0 0 0 1px rgba(254,44,85,0.45); }
  .footer-social .social-fb:hover, .footer-social .social-fb:focus-visible { background: #1877f2; border-color: transparent; box-shadow: 0 7px 20px rgba(24,119,242,0.45); }
  .footer-social .social-pin:hover, .footer-social .social-pin:focus-visible { background: #e60023; border-color: transparent; box-shadow: 0 7px 20px rgba(230,0,35,0.45); }
</style>
