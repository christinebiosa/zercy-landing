async function submitFreetextToZercy(turnId) {
  const textarea = document.getElementById('uqp-free-' + turnId);
  const text = textarea?.value?.trim();
  if (!text) return;
  zercyAdditions.push(text);
  textarea.value = '';
  const actionRow = document.getElementById('action-row-' + turnId);
  if (actionRow) actionRow.style.display = 'none';
  const repliesEl = document.getElementById('zercy-replies-' + turnId);
  const typingBubble = document.createElement('div');
  typingBubble.className = 'zercy-reply-bubble typing';
  typingBubble.innerHTML = `<div class="reply-orb"></div><span>${t(zercyLang, 'chatTyping')}</span>`;
  repliesEl.appendChild(typingBubble);
  repliesEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  try {
    const qidLabels = { from:'Flying FROM', return:'Return type', dates:'Travel dates', cabin:'Cabin class', nonstop:'Nonstop preference', miles:'Frequent flyer' };
    const chipParts = Object.entries(zercyAnswers).map(([qid, vals]) => vals.length ? `${qidLabels[qid]||qid}: ${vals.join(', ')}` : '').filter(Boolean);
    const textParts = Object.entries(zercyTextAnswers).map(([qid, val]) => val ? `${qidLabels[qid]||qid}: ${val}` : '').filter(Boolean);
    const context = [...chipParts, ...textParts, ...zercyAdditions.slice(0, -1).filter(Boolean)].join('; ');
    const res = await fetch('/api/think', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ intent: zercyOriginalIntent, mode: 'respond', context, addition: text })
    });
    const data = await res.json();
    typingBubble.remove();
    const bubble = document.createElement('div');
    bubble.className = 'zercy-reply-bubble';
    bubble.innerHTML = `<div class="reply-orb"></div><span>${data.reply || '...'}</span>`;
    repliesEl.appendChild(bubble);
  } catch { typingBubble.remove(); }
  finally { if (actionRow) actionRow.style.display = 'flex'; }
}

