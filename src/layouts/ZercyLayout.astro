const c = CONTENT[lang] || CONTENT.de;
const langs = ['en', 'de', 'es', 'fr', 'nl', 'it', 'pt'];
const getLangPath = (l: string) => l === 'de' ? '/' : `/${l}`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-EX8PVPV4NW"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-EX8PVPV4NW');
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={c.description} />
  <title>{c.title}</title>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="sitemap" href="/sitemap.xml" />
  <!-- hreflang for multilingual SEO -->
  <link rel="alternate" hreflang="de" href="https://www.zercy.app/" />
  <link rel="alternate" hreflang="en" href="https://www.zercy.app/en/" />
  <link rel="alternate" hreflang="es" href="https://www.zercy.app/es/" />
  <link rel="alternate" hreflang="fr" href="https://www.zercy.app/fr/" />
  <link rel="alternate" hreflang="nl" href="https://www.zercy.app/nl/" />
  <link rel="alternate" hreflang="it" href="https://www.zercy.app/it/" />
  <link rel="alternate" hreflang="pt" href="https://www.zercy.app/pt/" />
  <link rel="alternate" hreflang="x-default" href="https://www.zercy.app/" />
  <!-- OpenGraph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://www.zercy.app/" />
  <meta property="og:title" content={c.title} />
  <meta property="og:description" content={c.description} />
  <meta property="og:image" content="https://www.zercy.app/og-image.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://www.zercy.app/og-image.png" />
  <meta name="twitter:title" content={c.title} />
  <meta name="twitter:description" content={c.description} />
</head>
<body>

  <!-- BETA BANNER -->
  <div id="beta-banner" style="background:linear-gradient(90deg,#0EA5E9 0%,#F97316 100%);color:#fff;font-size:0.82rem;padding:0.55rem 3rem 0.55rem 1.2rem;text-align:center;position:relative;display:none;line-height:1.5;">
    {lang === 'en'
      ? <Fragment>Welcome! Zercy just launched. You&apos;re one of the first. If anything feels off, write us: <a href="mailto:info@zercy.app" style="color:#fff;font-weight:700;text-decoration:underline">info@zercy.app</a></Fragment>
      : <Fragment>Willkommen! Zercy ist gerade frisch gestartet. Du bist früh dabei. Falls etwas hakt, schreib uns: <a href="mailto:info@zercy.app" style="color:#fff;font-weight:700;text-decoration:underline">info@zercy.app</a></Fragment>
    }
    <button onclick="dismissBeta()" style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);background:none;border:none;color:rgba(255,255,255,0.8);cursor:pointer;font-size:1.2rem;line-height:1;padding:0.2rem 0.3rem">&times;</button>
  </div>
  <script is:inline>
    (function(){
      if(!localStorage.getItem('zercy_beta_ok')){
        document.getElementById('beta-banner').style.display='block';
      }
    })();
    function dismissBeta(){
      localStorage.setItem('zercy_beta_ok','1');
      document.getElementById('beta-banner').style.display='none';
    }
  </script>

  <!-- NAV -->
  <nav>
    <div class="container nav-inner">
      <a href="/" class="logo">
        <span class="logo-icon">✈</span>
        <span class="logo-text-wrap">
          <span class="logo-text">Zercy</span>
          {c.pronounce && <span class="logo-pronounce">{c.pronounce}</span>}
        </span>
      </a>
      <div class="nav-links">
        <a href="#features">{c.navFeatures}</a>
        <a href="#how-it-works">{c.navHowItWorks}</a>
        {lang === 'de' && <a href="/blog" class="btn-nav-pill btn-nav-blog" target="_blank" rel="noopener">Blog</a>}
        {lang === 'en' && <a href="/en/blog" class="btn-nav-pill btn-nav-blog" target="_blank" rel="noopener">Blog</a>}
        <a href="/logbook" class="btn-nav-pill btn-nav-logbook" target="_blank" rel="noopener">Logbook</a>
        <div class="nav-divider"></div>
        <div class="lang-switcher">
          {lang === 'en'
            ? <span class="lang active">EN</span>
            : <a href="/en" class="lang">EN</a>
          }
          <span class="lang-sep">|</span>
          {lang === 'de'
            ? <span class="lang active">DE</span>
            : <a href="/" class="lang">DE</a>
          }
          <div class="lang-more-wrapper">
            <button class="lang-more-btn" onclick="toggleLangDropdown(event)">+5 ▾</button>
            <div class="lang-dropdown" id="lang-dropdown">
              {['es','fr','nl','it','pt'].map((l) => (
                l === lang
                  ? <span class="lang-dd-item active">{l.toUpperCase()}</span>
                  : <a href={getLangPath(l)} class="lang-dd-item">{l.toUpperCase()}</a>
              ))}
            </div>
          </div>
        </div>
        <button id="newSearchBtn" onclick="newSearch()" class="btn-new-search" style="display:none">{c.newSearchLabel}</button>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="container">
      <div class="hero-badges">
        <div class="hero-badge">
          <span class="badge-dot"></span>
          {c.badge1}
        </div>
        <div class="hero-badge hero-badge-plain">{c.badge2}</div>
      </div>
      <h1 class="hero-title">
        <span class="title-slate">{c.titleLine1}</span><br />
        <span class="title-blue">{c.titleLine2}</span><br />
        <span class="gradient-text">{c.titleLine3}</span>
      </h1>
      <p class="hero-subtitle" set:html={c.subtitle}></p>

      <div class="hero-chat">
        <div class="hero-chat-bubble">
          <div class="chat-avatar">Z</div>
          <div class="chat-text">{c.chatBubble}</div>
        </div>
        <div class="hero-input-row">
          <input
            type="text"
            id="intent"
            class="hero-input"
            placeholder=""
            autofocus
            onkeydown="if(event.key==='Enter')thinkIntent()"
          />
          <button id="searchBtn" class="hero-search-btn" onclick="thinkIntent()">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
          </button>
        </div>
      </div>

      <div class="hero-chips">
        {c.chips.map((chip: string) => (
          <span class="chip" onclick="useChip(this.innerText)">{chip}</span>
        ))}
      </div>

    </div>
  </section>

  <!-- RESULTS WRAPPER -->
  <div id="zercy-results-wrapper" style="display:none">
    <div id="zercy-content">
      <div id="loading" style="display:none;">
        <div class="zercy-loading-card">
          <div class="zercy-loading-orb">
            <div class="orb">
              <div class="orb-eye left">Z</div>
              <div class="orb-eye right">C</div>
              <div class="orb-sparkle s1"></div>
              <div class="orb-sparkle s2"></div>
              <div class="orb-sparkle s3"></div>
            </div>
          </div>
          <ol id="loading-steps" class="loading-steps" aria-live="polite"></ol>
        </div>
      </div>
      <div id="conversation"></div>
    </div>
  </div>

  <!-- STRIP -->
  <div class="strip">
    <div class="container strip-inner">
      {c.strip.map((item: string, i: number) => (
        <>
          <span>{item}</span>
          {i < c.strip.length - 1 && <span class="strip-dot">·</span>}
        </>
      ))}
    </div>
  </div>

  <!-- FEATURES -->
  <section id="features" class="features">
    <div class="container">
      <div class="section-header">
        <h2>{c.featuresTitle}</h2>
        <p>{c.featuresSub}</p>
      </div>
      <div class="features-grid">
        {c.features.map((f: any, i: number) => (
          <div class={`feature-card${i === 0 ? ' featured' : ''}`}>
            <div class="feature-icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.5rem;">
        <button onclick="scrollToSearch()" class="btn-primary cta-btn">
          {c.ctaBtn}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class="how-it-works">
    <div class="container">
      <div class="section-header">
        <h2>{c.stepsTitle}</h2>
        <p>{c.stepsSub}</p>
      </div>
      <div class="steps">
        {c.steps.map((step: any, i: number) => (
          <>
            <div class="step">
              <div class="step-number">{i + 1}</div>
              <div class="step-content">
                <h3>{step.title}</h3>
                <p>{step.desc}</p>
              </div>
            </div>
            {i < c.steps.length - 1 && (
              <div class="step-connector"><div class="connector-line"></div></div>
            )}
          </>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.5rem;">
        <button onclick="scrollToSearch()" class="btn-primary cta-btn">
          {c.ctaBtn}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- LOGBOOK -->
  <section class="logbook-promo">
    <div class="container">
      <div class="logbook-promo-inner">
        <div class="logbook-promo-text">
          <div class="logbook-label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            Zercy Logbook
          </div>
          <h2>{c.logbookTitle}</h2>
          <p>{c.logbookSub}</p>
          <ul class="logbook-bullets">
            {c.logbookBullets.map((b: string) => (
              <li>
                <span class="logbook-bullet-dot">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </span>
                {b}
              </li>
            ))}
          </ul>
          <a href="/logbook" class="btn-logbook-cta" target="_blank" rel="noopener">
            {c.logbookCta}
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>

        <div class="logbook-promo-visual">
          <div class="lp-mock">
