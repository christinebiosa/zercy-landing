      es: { morning: '☀️ Mañana', afternoon: '🌤 Tarde', evening: '🌙 Noche' },
      nl: { morning: '☀️ Ochtend', afternoon: '🌤 Middag', evening: '🌙 Avond' },
      it: { morning: '☀️ Mattina', afternoon: '🌤 Pomeriggio', evening: '🌙 Sera' },
      pt: { morning: '☀️ Manhã', afternoon: '🌤 Tarde', evening: '🌙 Noite' }
    }[zercyLang] || { morning: '☀️ Morning', afternoon: '🌤 Afternoon', evening: '🌙 Evening' };
    const dayLabel = { de:'Tag', en:'Day', fr:'Jour', es:'Día', nl:'Dag', it:'Giorno', pt:'Dia' }[zercyLang] || 'Day';
    const extraTitle = { de:'Zusätzliche Tipps', en:'Extra tips', fr:'Conseils bonus', es:'Consejos extra', nl:'Extra tips', it:'Suggerimenti extra', pt:'Dicas extras' }[zercyLang] || 'Extra tips';

    const renderBlock = (block, iconKey) => {
      if (!block || !block.activity) return '';
      return `<div class="ideas-time-block">
        <span class="ideas-time-icon">${timeLabels[iconKey].split(' ')[0]}</span>
        <div class="ideas-time-content">
          <div class="ideas-time-activity">${timeLabels[iconKey].split(' ').slice(1).join(' ')}: ${block.activity}</div>
          ${block.tip ? `<div class="ideas-time-tip">${block.tip}</div>` : ''}
          ${block.price ? `<span class="ideas-time-price">${block.price}</span>` : ''}
        </div>
      </div>`;
    };

    const daysHtml = (data.days || []).map(d => `
      <div class="ideas-day-card">
        <div class="ideas-day-header">
          <span class="ideas-day-number">${dayLabel} ${d.day}</span>
          <span class="ideas-day-title">${d.title || ''}</span>
        </div>
        ${renderBlock(d.morning, 'morning')}
        ${renderBlock(d.afternoon, 'afternoon')}
        ${renderBlock(d.evening, 'evening')}
      </div>
    `).join('');

    const extraHtml = (data.extra_tips && data.extra_tips.length) ? `
      <div class="ideas-extra-tips">
        <div class="ideas-extra-title">${extraTitle}</div>
        <ul class="ideas-extra-list">
          ${data.extra_tips.map(tip => `<li>${tip}</li>`).join('')}
        </ul>
      </div>` : '';

    container.innerHTML = `
      <div class="ideas-header">
        <span class="ideas-header-icon">✨</span>
        <span class="ideas-header-title">Zercy${zercyLang === 'de' || zercyLang === 'nl' ? 's' : "'s"} ${{ de:'Ideen für', en:'Ideas for', fr:'Idées pour', es:'Ideas para', nl:'Ideeën voor', it:'Idee per', pt:'Ideias para' }[zercyLang] || 'Ideas for'} ${destination}</span>
