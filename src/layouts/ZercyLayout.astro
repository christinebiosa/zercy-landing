  .orb { width: 44px; height: 44px; border-radius: 50%; background: radial-gradient(circle at 35% 35%, #a78bfa, #4f46e5 50%, #0ea5e9); box-shadow: 0 0 18px rgba(99,102,241,0.6), 0 0 40px rgba(14,165,233,0.3); position: relative; animation: orb-pulse 1.2s ease-in-out infinite alternate; }
