function t(lang, key, subkey) {
  const labels = L[lang] || L['de'];
  if (subkey) return (labels[key] && labels[key][subkey]) || (L['de'][key] && L['de'][key][subkey]) || subkey;
  return labels[key] !== undefined ? labels[key] : (L['de'][key] !== undefined ? L['de'][key] : key);
}

function applyLanguageToStaticUI(lang) {
  const nb = document.getElementById('newSearchBtn');
  if (nb) nb.textContent = t(lang, 'newSearch');
  const chatInput = document.getElementById('chat-input');
  if (chatInput) chatInput.placeholder = t(lang, 'chatInputPlaceholder');
  const container = document.getElementById('chat-suggestions');
  if (container) container.innerHTML = '';
}

function showInlineLoading() {
  const el = document.createElement('div');
  el.id = 'inline-loading';
  el.style.cssText = 'text-align:center;padding:1.5rem;';
  el.innerHTML = `
    <div class="loader-scene">
      <div class="zercy-mascot"><div class="orb">
        <div class="orb-eye left">Z</div><div class="orb-eye right">C</div>
        <div class="orb-sparkle s1"></div><div class="orb-sparkle s2"></div><div class="orb-sparkle s3"></div>
      </div></div>
      <span class="plane-loader">✈️</span>
    </div>
    <p style="color:#94a3b8;font-size:0.9rem;font-weight:500;" id="inline-loading-text">${t(zercyLang, 'chatTyping')}</p>
  `;
  document.getElementById('conversation').appendChild(el);
  el.scrollIntoView({ behavior: 'smooth', block: 'center' });
  return el;
}

async function thinkIntent() {
  const intent = document.getElementById('intent').value.trim();
  if (!intent) return;
  zercyOriginalIntent = intent;
  zercyAnswers = {}; zercyAdditions = []; zercyTextAnswers = {};
  lastIntent = intent;
  const heroEl = document.getElementById('hero');
  if (heroEl) heroEl.classList.add('compact');
  const wrapper = document.getElementById('zercy-results-wrapper');
  if (wrapper) wrapper.style.display = 'block';
  document.getElementById('searchBtn').disabled = true;
  document.getElementById('loading-text').textContent = t(zercyLang, 'loadingThink');
  document.getElementById('loading').style.display = 'block';
  document.getElementById('conversation').innerHTML = '';
  try {
    const res = await fetch('/api/think', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ intent })
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
    currentPlanData = data;
    zercyLang = data.language || zercyLang;
    applyLanguageToStaticUI(zercyLang);
    if (data.car_only) {
      await appendCarPlanTurn(intent, data);
      return;
    }
    await appendPlanTurn(intent, data);
    if (data.understood) {
      const u = data.understood;
      const enrichments = [];
      if (u.origin) enrichments.push(`Origin: ${u.origin}`);
      if (u.destination_area) enrichments.push(`Destination: ${u.destination_area}`);
      if (u.outbound_window) enrichments.push(`Outbound timeframe: ${u.outbound_window}`);
      if (u.return_window && u.return_window !== 'null') enrichments.push(`Return timeframe: ${u.return_window}`);
      if (u.cabin) enrichments.push(`Cabin: ${u.cabin}`);
      if (u.nonstop_preference && u.nonstop_preference !== 'flexible') enrichments.push(`Nonstop: ${u.nonstop_preference}`);
      if (enrichments.length) lastIntent += '. Zercy understood: ' + enrichments.join(', ');
    }
  } catch (err) {
    const conversation = document.getElementById('conversation');
    if (conversation) {
      const errEl = document.createElement('div');
      errEl.className = 'zercy-error-bubble';
      errEl.innerHTML = `<span>${t(zercyLang, 'thinkError')} <small style="opacity:0.6">(${err.message})</small></span>`;
      conversation.appendChild(errEl);
      errEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  } finally {
    document.getElementById('searchBtn').disabled = false;
    document.getElementById('loading').style.display = 'none';
  }
}

async function parseIntent(refinedIntent) {
  const intent = refinedIntent || zercyOriginalIntent || document.getElementById('intent').value.trim();
  if (!intent) return;
  lastIntent = intent;
  const inlineLoader = showInlineLoading();
  document.getElementById('loading-text').textContent = t(zercyLang, 'loadingSearch');
  try {
    const res = await fetch('/api/parse', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        intent,
        planContext: currentPlanData ? {
          narrative: currentPlanData.narrative,
          smartInsights: currentPlanData.smart_insights,
          understood: currentPlanData.understood
        } : null
      })
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
    appendTurn(intent, data, true);
  } catch (err) {
    const conversation = document.getElementById('conversation');
    if (conversation) {
      const errEl = document.createElement('div');
      errEl.className = 'zercy-error-bubble';
      errEl.innerHTML = `<span>${t(zercyLang, 'searchError')} <small style="opacity:0.6">(${err.message})</small></span>`;
      conversation.appendChild(errEl);
    }
  } finally {
    if (inlineLoader) inlineLoader.remove();
  }
}

function collectAnswersAndSearch(turnId) {
  const parts = [zercyOriginalIntent];
  const qidLabels = { from:'Flying FROM (origin)', return:'Return type', dates:'Travel duration/dates', cabin:'Cabin class', nonstop:'Nonstop preference', miles:'Frequent flyer program' };
  Object.entries(zercyAnswers).forEach(([id, values]) => { if (values && values.length > 0) parts.push(`${qidLabels[id]||id}: ${values.join(', ')}`); });
  Object.entries(zercyTextAnswers).forEach(([id, val]) => { if (val) parts.push(`${qidLabels[id]||id} (typed): ${val}`); });
  const freetextEl = document.getElementById('uqp-free-' + turnId);
  const freetextVal = freetextEl?.value?.trim();
  if (freetextVal) parts.push(freetextVal);
  zercyAdditions.filter(Boolean).forEach(a => parts.push(a));
  const u = currentPlanData?.understood;
  if (u) {
    const enrichments = [];
    if (u.origin) enrichments.push(`Origin: ${u.origin}`);
    if (u.destination_area) enrichments.push(`Destination: ${u.destination_area}`);
    if (u.outbound_window) enrichments.push(`Outbound timeframe: ${u.outbound_window}`);
    if (u.return_window && u.return_window !== 'null') enrichments.push(`Return timeframe: ${u.return_window}`);
    if (u.cabin) enrichments.push(`Cabin: ${u.cabin}`);
    if (u.nonstop_preference && u.nonstop_preference !== 'flexible') enrichments.push(`Nonstop: ${u.nonstop_preference}`);
    if (enrichments.length) parts.push('Zercy understood: ' + enrichments.join(', '));
  }
  const fullIntent = parts.join('. ');
  lastIntent = fullIntent;
  parseIntent(fullIntent);
}

function parseDateToISO(s) {
  if (!s) return '';
  s = s.trim();
  // Normalize: collapse whitespace, strip ordinal suffixes (1st→1, 2nd→2, 3rd→3, 10th→10), strip commas
  s = s.replace(/\s+/g, ' ').replace(/(\d)(st|nd|rd|th)\b/gi, '$1').replace(/,/g, '').trim();
  if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
  const yr = 2026;
  // DD.MM.YYYY
  const a = s.match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})$/);
  if (a) return `${a[3]}-${a[2].padStart(2,'0')}-${a[1].padStart(2,'0')}`;
  // DD/MM/YYYY
  const b = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (b) return `${b[3]}-${b[2].padStart(2,'0')}-${b[1].padStart(2,'0')}`;
  // DD.MM. or DD.MM (no year)
  const c = s.match(/^(\d{1,2})\.(\d{1,2})\.?$/);
  if (c) return `${yr}-${c[2].padStart(2,'0')}-${c[1].padStart(2,'0')}`;
  // "5. Oktober", "5. Oktober 2026", "5 Oktober", "5 Okt 2026" etc.
  const mn = {jan:1,feb:2,mär:3,mar:3,apr:4,mai:5,may:5,jun:6,jul:7,aug:8,sep:9,okt:10,oct:10,nov:11,dez:12,dec:12,januar:1,februar:2,'märz':3,april:4,juni:6,juli:7,august:8,september:9,oktober:10,november:11,dezember:12,january:1,february:2,march:3,june:6,july:7,august:8,september:9,october:10,november:11,december:12,janvier:1,mars:3,mai:5,juin:6,juillet:7,août:8,septembre:9,octobre:10,novembre:11,décembre:12,enero:1,marzo:3,mayo:5,junio:6,julio:7,agosto:8,septiembre:9,octubre:10,noviembre:11,diciembre:12};
  const lookupMonth = w => { const k = w.toLowerCase(); return mn[k] || mn[k.substring(0,3)] || 0; };
  // day-first: "10 Oktober", "10. Oktober", "10 Okt", "10. Okt 2026"
  const d = s.match(/^(\d{1,2})\.?\s+([a-züäöéàâêôûç]+)(?:\.|\s+(\d{4}))?$/i);
  if (d) { const m = lookupMonth(d[2]); if (m) return `${d[3]||yr}-${String(m).padStart(2,'0')}-${d[1].padStart(2,'0')}`; }
  // month-first: "Oktober 10", "Oct 10", "October 10 2026"
  const e = s.match(/^([a-züäöéàâêôûç]+)\.?\s+(\d{1,2})(?:\.?\s+(\d{4}))?$/i);
  if (e) { const m = lookupMonth(e[1]); if (m) return `${e[3]||yr}-${String(m).padStart(2,'0')}-${e[2].padStart(2,'0')}`; }
  return '';
}

function collectCarAnswersAndSearch(turnId) {
  const pickup = document.getElementById('car-pickup-' + turnId)?.value?.trim() || '';
  const dropoff = document.getElementById('car-dropoff-' + turnId)?.value?.trim() || '';
  const fromDate = document.getElementById('car-fromdate-' + turnId)?.value?.trim() || '';
  const toDate = document.getElementById('car-todate-' + turnId)?.value?.trim() || '';
  const vehicleClass = (zercyAnswers['carclass'] || []).join(', ');
  // Store form dates directly — don't rely on Claude to re-extract them
  pendingCarDates = {
    pickupCity: pickup,
    dropoffCity: dropoff,
    pickupDate: parseDateToISO(fromDate) || fromDate,
    returnDate: parseDateToISO(toDate) || toDate
  };
  const parts = ['Car rental request'];
  if (pickup) parts.push(`pickup city: ${pickup}`);
  if (dropoff) parts.push(`dropoff city: ${dropoff}`);
  if (fromDate) parts.push(`pickup date: ${fromDate}`);
  if (toDate) parts.push(`return date: ${toDate}`);
  if (vehicleClass) parts.push(`vehicle class: ${vehicleClass}`);
  const fullIntent = parts.join(', ');
  lastIntent = fullIntent;
  parseIntent(fullIntent);
}

function toggleAnswerChip(questionId, value, el) {
  if (!zercyAnswers[questionId]) zercyAnswers[questionId] = [];
  const idx = zercyAnswers[questionId].indexOf(value);
  if (idx >= 0) { zercyAnswers[questionId].splice(idx, 1); el.classList.remove('selected'); }
  else { zercyAnswers[questionId].push(value); el.classList.add('selected'); }
}

function buildFormRow({ qid, label, knownValue, chips, hasText, textPlaceholder }) {
  return `
    <div class="zfp-row">
      <div class="zfp-label">${label}</div>
      <div class="zfp-controls" id="ctrl-${qid}">
        ${knownValue ? `<div class="zfp-known">✓ ${knownValue}</div><br>` : ''}
        <div class="answer-chips" id="chips-${qid}">
          ${chips.map(c => `<button class="answer-chip" onclick="toggleAnswerChip('${qid}','${c.replace(/'/g,"\\'")}',this)">${c}</button>`).join('')}
        </div>
        ${hasText ? `<input type="text" class="zfp-text-input" id="input-${qid}" placeholder="${textPlaceholder}" oninput="setTextAnswer('${qid}',this.value)">` : ''}
      </div>
    </div>`;
}

