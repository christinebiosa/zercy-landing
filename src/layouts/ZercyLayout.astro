async function detectUserLocation() {
  try {
    const r = await fetch('https://ipapi.co/json/');
    const d = await r.json();
    if (d.city && d.country_name) return `${d.city}, ${d.country_name}`;
    return d.country_name || null;
  } catch { return null; }
}

const L = {
  de: {
    planLabel:'Zercy hat einen Plan', understood:'Was Zercy verstanden hat',
    from:'Von', to:'Ziel', cabin:'Kabine', outbound:'Hinflug', returnTrip:'Rückflug',
    nonstop:'Nonstop', duration:'Reisedauer', routes:'Route-Optionen die Zercy sieht',
