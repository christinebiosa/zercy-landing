function toggleFlightView(view, turnId) {
  const turn = document.getElementById('turn-' + turnId);
  if (!turn) return;
  const grid = turn.querySelector('.grid-2');
  const table = turn.querySelector('.flight-table-wrap');
  const btns = turn.querySelectorAll('.view-toggle-btn');
  btns.forEach(b => b.classList.toggle('active', b.dataset.view === view));
  if (view === 'table') {
    if (grid) grid.style.display = 'none';
    if (table) table.style.display = 'block';
  } else {
    if (grid) grid.style.display = '';
    if (table) table.style.display = 'none';
  }
}

function sortFlightTable(th, col) {
  const table = th.closest('.flight-table');
  const tbody = table.querySelector('tbody');
  const rows = Array.from(tbody.querySelectorAll('tr'));
  const wasAsc = th.classList.contains('ft-sorted');
  table.querySelectorAll('th').forEach(h => { h.classList.remove('ft-sorted', 'ft-sorted-desc'); h.textContent = h.textContent.replace(/ [↓↑]/, ''); });
  const asc = !wasAsc;
  th.classList.add(asc ? 'ft-sorted' : 'ft-sorted-desc');
  th.textContent += asc ? ' ↓' : ' ↑';
  const colIdx = { airline: 0, airport: 1, price: 2, duration: 3, stops: 4, timing: 5 }[col];
  rows.sort((a, b) => {
    let va = a.cells[colIdx].textContent.trim();
    let vb = b.cells[colIdx].textContent.trim();
    if (col === 'price') { va = parseInt(va.replace(/[^0-9]/g, '')) || 0; vb = parseInt(vb.replace(/[^0-9]/g, '')) || 0; }
    else if (col === 'duration') { va = parseInt(va) * 60 + (parseInt(va.split('h')[1]) || 0); vb = parseInt(vb) * 60 + (parseInt(vb.split('h')[1]) || 0); }
    else if (col === 'stops') { va = va.includes('nonstop') ? 0 : parseInt(va) || 0; vb = vb.includes('nonstop') ? 0 : parseInt(vb) || 0; }
    if (typeof va === 'number') return asc ? va - vb : vb - va;
    return asc ? va.localeCompare(vb) : vb.localeCompare(va);
  });
  rows.forEach(r => tbody.appendChild(r));
}

function buildFlightTableHtml(d, turnId) {
  const rows = [];
  const originCode = d.origin?.airport || '';
  const outDate = d.outbound?.recommended_date || '';
  const retDate = d.return?.recommended_date || '';
  (d.outbound?.suggested_airports || []).forEach(a => {
    (a.flights || []).forEach(f => {
      rows.push({ ...f, airportCode: a.code, airportCity: a.city });
    });
  });
  (d.return?.suggested_airports || []).forEach(a => {
    (a.flights || []).forEach(f => {
      rows.push({ ...f, airportCode: a.code, airportCity: a.city, isReturn: true });
    });
  });
  if (rows.length < 3) return '';
  rows.sort((a, b) => (a.price || 9999) - (b.price || 9999));

  const tableRows = rows.map((f, i) => {
    const dur = `${Math.floor(f.duration/60)}h${f.duration%60 ? f.duration%60+'m' : ''}`;
    const timing = f.departure ? `${f.departure}→${f.arrival}` : '';
    const stopsLabel = f.stops === 0 ? `<span class="flight-nonstop">nonstop</span>` : `${f.stops} stop`;
    const leg1 = f.isReturn ? f.airportCode : originCode;
    const leg2 = f.isReturn ? originCode : f.airportCode;
    const gflLegDate = f.isReturn ? retDate : outDate;
    const gflUrl = retDate && outDate && !f.isReturn
      ? zercyUrls.googleFlights(originCode, f.airportCode, outDate, retDate)
      : zercyUrls.googleFlights(leg1, leg2, gflLegDate);
    const cheapestClass = i === 0 ? ' ft-cheapest' : '';
    const dirLabel = f.isReturn ? '↩' : '→';
    return `<tr class="ft-row${cheapestClass}" onclick="window.open('${gflUrl}','_blank')">
      <td class="ft-airline">✈ ${f.airline}</td>
      <td class="ft-airport">${dirLabel} ${f.airportCode}</td>
      <td class="ft-price">€${f.price}</td>
      <td class="ft-duration">${dur}</td>
      <td class="ft-stops">${stopsLabel}</td>
      <td class="ft-timing">${timing}</td>
    </tr>`;
  }).join('');

  return `
  <div class="flight-table-wrap" style="display:none;">
    <table class="flight-table">
      <thead><tr>
        <th onclick="sortFlightTable(this,'airline')">Airline</th>
        <th onclick="sortFlightTable(this,'airport')">Airport</th>
        <th class="ft-sorted" onclick="sortFlightTable(this,'price')">Price ↓</th>
        <th onclick="sortFlightTable(this,'duration')">Duration</th>
        <th onclick="sortFlightTable(this,'stops')">Stops</th>
        <th onclick="sortFlightTable(this,'timing')">Timing</th>
      </tr></thead>
      <tbody>${tableRows}</tbody>
    </table>
  </div>`;
}

function buildResultsHtml(d, id) {
  if (d.car_only) return buildCarOnlyHtml(d);
  if (d.travel_mode === 'ground_only') return groundOnlyHtml(d);
  if (d.travel_mode === 'hotel_only') return hotelOnlyHtml(d);

  const hotelDest = d.outbound?.destination_intent || '';
  const hotelCheckin = d.outbound?.recommended_date || '';
  // If no checkout date, default to checkin + 7 days
  const hotelCheckout = d.return?.recommended_date || (() => {
    if (!d.outbound?.recommended_date) return '';
    const dt = new Date(d.outbound.recommended_date + 'T00:00:00');
    dt.setDate(dt.getDate() + 7);
    return dt.toISOString().split('T')[0];
  })();

  const airportHtml = (airports, isReturn = false) => airports.map(a => {
    const gt = a.ground_transport;
    const groundHtml = gt ? (() => {
      const dest = gt.destination || a.city;
      const distLabel = gt.distance_km ? ` · ${gt.distance_km} km` : '';
      const header = isReturn ? `🚗 ${dest} → ${a.code}${distLabel}` : `🚗 ${a.code} → ${dest}${distLabel}`;
      const mapsOriginRaw = isReturn ? dest : (a.city + ' Airport');
      const mapsDestRaw = isReturn ? (a.city + ' Airport') : dest;
      const mapsO = encodeURIComponent(mapsOriginRaw);
      const mapsD = encodeURIComponent(mapsDestRaw);
      const opts = gt.options || [];
      const optRows = opts.map(opt => {
        let btnUrl, btnLabel;
        if (opt.maps_mode === 'driving') {
          btnUrl = zercyUrls.googleMaps(mapsO, mapsD, 'driving');
          btnLabel = '🗺 Maps';
        } else if (opt.maps_mode === 'search') {
          btnUrl = `https://www.google.com/search?q=${encodeURIComponent((opt.label || '') + ' ' + mapsOriginRaw + ' to ' + mapsDestRaw)}`;
          btnLabel = '🔍 Search';
        } else {
          btnUrl = zercyUrls.googleMaps(mapsO, mapsD, 'transit');
          btnLabel = '🗺 Maps';
        }
        const meta = [opt.duration, opt.cost].filter(Boolean).join(' · ');
        return `<div style="display:flex;align-items:center;gap:0.6rem;padding:0.38rem 0;border-bottom:1px solid rgba(16,185,129,0.12);">
          <span style="font-size:1rem;width:1.4rem;text-align:center;flex-shrink:0;">${opt.icon || '🚌'}</span>
          <div style="flex:1;min-width:0;">
            <div style="font-size:0.79rem;font-weight:700;color:#065f46;">${opt.label || ''}</div>
            ${meta ? `<div style="font-size:0.71rem;color:#6b7280;">${meta}</div>` : ''}
          </div>
          <a href="${btnUrl}" target="_blank" rel="noopener" style="font-size:0.71rem;font-weight:700;color:#065f46;text-decoration:none;white-space:nowrap;flex-shrink:0;">${btnLabel} ↗</a>
        </div>`;
      }).join('');
      const body = optRows || `<a class="ground-app-btn maps-btn" href="${zercyUrls.googleMaps(mapsO, mapsD, 'transit')}" target="_blank" rel="noopener">🗺 Google Maps ↗</a>`;
      return `<div class="ap-section green">
        <div class="ap-section-header">${header}</div>
        <div class="ap-section-body">${body}</div>
      </div>`;
    })() : '';

    return `
    <div class="airport-item">
      <div class="airport-code">${a.code}</div>
      <div style="flex:1;min-width:0;overflow:hidden">
        <div class="airport-city">${a.city}</div>
        <div class="airport-reason">${a.reason}</div>
        ${(() => {
          const origin = d.origin?.airport || '';
          const outDate = d.outbound?.recommended_date || '';
          const retDate = d.return?.recommended_date || '';
          const leg1 = isReturn ? a.code : origin;
          const leg2 = isReturn ? origin : a.code;
          const flightDate = isReturn ? retDate : outDate;
          const fromCity = isReturn ? (a.city || leg1) : (d.origin?.city || leg1);
          const toCity = isReturn ? (d.origin?.city || leg2) : (a.city || leg2);
          const gflUrl = retDate && !isReturn && outDate
            ? zercyUrls.googleFlights(origin, a.code, outDate, retDate)
            : zercyUrls.googleFlights(leg1, leg2, flightDate);
          const expUrl = retDate && !isReturn
            ? zercyUrls.expediaFlights(leg1, leg2, outDate, retDate, d.cabin)
            : zercyUrls.expediaFlights(leg1, leg2, flightDate, null, d.cabin);
          const flightHeader = `✈ ${leg1} → ${leg2}`;

          if (a.isRoundtripSameAirport) {
            return `<div class="ap-section blue">
              <div class="ap-section-header">${flightHeader}</div>
              <div class="ap-section-body">
                <div style="font-size:0.78rem;color:#94a3b8;padding:0.2rem 0 0.4rem;">Im Roundtrip-Preis bereits enthalten.</div>
                <div class="flight-fallback-row">
                  <a class="flight-book-btn gfl-btn" href="${gflUrl}" target="_blank" rel="noopener">🔍 Google Flights ↗</a>
                  <a class="flight-book-btn exp-btn" href="${expUrl}" target="_blank" rel="noopener">🔍 Expedia ↗</a>
                </div>
              </div>
            </div>`;
          }

          if (a.flights && a.flights.length > 0) {
            // Compute smart logistics notes
            const computedNotes = [];
            const nonstops = a.flights.filter(f => f.stops === 0);
            const withStops = a.flights.filter(f => f.stops > 0);
            if (nonstops.length > 0 && withStops.length > 0) {
              const nsCheap = Math.min(...nonstops.map(f => f.price));
              const stCheap = Math.min(...withStops.map(f => f.price));
              if (nsCheap > stCheap) computedNotes.push(`Nonstop +€${nsCheap - stCheap} vs. ${withStops[0].stops}-stop, ${Math.round((nonstops[0].duration - withStops[0].duration)/60)}h ${zercyLang === 'de' ? 'schneller' : 'faster'}`);
            }
            const earliest = a.flights.reduce((e, f) => (!e || (f.arrival && f.arrival < e.arrival)) ? f : e, null);
            if (earliest?.arrival && !isReturn) {
              const arrH = parseInt(earliest.arrival.split(':')[0]);
              if (arrH <= 14) computedNotes.push(zercyLang === 'de' ? `Früheste Ankunft ${earliest.arrival}, ganzer Tag am Ziel` : `Earliest arrival ${earliest.arrival}, full day at destination`);
            }
            if (nonstops.length > 0 && nonstops.length === a.flights.length) {
              const dur = Math.floor(nonstops[0].duration / 60);
              computedNotes.push(zercyLang === 'de' ? `Alle Flüge nonstop, ca. ${dur}h Flugzeit` : `All flights nonstop, ~${dur}h flight time`);
            }
            const allNotes = [...(a.flight_notes || []), ...computedNotes].slice(0, 3);
            const notesHtml = allNotes.length ? `<div class="flight-notes">${allNotes.map(n => `<span class="flight-note">💡 ${n}</span>`).join('')}</div>` : '';

            return `<div class="ap-section blue">
              <div class="ap-section-header">${flightHeader}</div>
              <div class="ap-section-body">
                <div class="flight-cards">
                  ${a.flights.map(f => `
                    <div class="flight-card">
                      <div class="flight-card-top">
                        <span class="flight-airline">✈ ${f.airline}</span>
                        <span class="flight-price">€${f.price}</span>
                      </div>
                      <div class="flight-card-bottom">
                        ${f.departure ? `<span>${f.departure}</span><span>→</span><span>${f.arrival}</span><span>·</span>` : ''}
                        <span>${Math.floor(f.duration/60)}h${f.duration%60 ? f.duration%60+'m' : ''}</span>
                        <span>·</span>
                        <span class="${f.stops === 0 ? 'flight-nonstop' : ''}">${f.stops === 0 ? 'nonstop' : f.stops + ' stop'}</span>
                      </div>
                      <div class="flight-book-row">
                        <a class="flight-book-btn gfl-btn" href="${gflUrl}" target="_blank" rel="noopener">Google Flights ↗</a>
                        <a class="flight-book-btn exp-btn" href="${expUrl}" target="_blank" rel="noopener">Expedia ↗</a>
                      </div>
                    </div>
                  `).join('')}
                </div>
                ${notesHtml}
              </div>
            </div>`;
          } else {
            return `<div class="ap-section blue">
              <div class="ap-section-header">${flightHeader}</div>
              <div class="ap-section-body">
                <div style="font-size:0.75rem;color:#94a3b8;margin-bottom:0.4rem;">Keine Live-Preise — direkt suchen:</div>
                <div class="flight-fallback-row">
                  <a class="flight-book-btn gfl-btn" href="${gflUrl}" target="_blank" rel="noopener">🔍 Google Flights ↗</a>
                  <a class="flight-book-btn exp-btn" href="${expUrl}" target="_blank" rel="noopener">🔍 Expedia ↗</a>
                </div>
              </div>
            </div>`;
          }
        })()}
        ${groundHtml}
        ${!isReturn && hotelDest ? (() => {
          const cleanDest = hotelDest || gt?.destination || a.city;
          const googleHotelUrl = zercyUrls.googleHotels(cleanDest, hotelCheckin, hotelCheckout);
          const bookingSearchUrl = zercyUrls.bookingHotels(cleanDest, hotelCheckin, hotelCheckout);
          const expediaSearchUrl = zercyUrls.expediaHotels(cleanDest, hotelCheckin, hotelCheckout);
          return `<div class="ap-section purple">
            <div class="ap-section-header">🏨 Hotels in ${cleanDest} <span class="hotel-price-from"></span></div>
            <div class="ap-section-body" data-hotel-prices="hp-${Math.random().toString(36).slice(2,8)}" data-hotel-dest="${cleanDest.replace(/"/g,'&quot;')}" data-hotel-ci="${hotelCheckin || ''}" data-hotel-co="${hotelCheckout || ''}">
              <a class="hotel-btn google-btn" data-hotel-src="google" href="${googleHotelUrl}" target="_blank" rel="noopener">Google Hotels</a>
              <a class="hotel-btn booking-btn" data-hotel-src="booking" href="${bookingSearchUrl}" target="_blank" rel="noopener">Booking.com</a>
              <a class="hotel-btn expedia-btn" data-hotel-src="expedia" href="${expediaSearchUrl}" target="_blank" rel="noopener">Expedia</a>
            </div>
          </div>`;
        })() : ''}
        ${!isReturn && hotelCheckin && hotelCheckout ? (() => {
          // Use car_rental city from parse.js if available, else fall back to airport city
          const carCity = d.car_rental?.pickup_city || a.city || '';
          const carPickup = d.car_rental?.pickup_date || hotelCheckin;
          const carDropoff = d.car_rental?.dropoff_date || hotelCheckout;
          const expUrl = zercyUrls.expediaCars(carCity, carPickup, carDropoff);
          const dcCarBtn = zercyUrls.discoverCars(carCity);
          const carLabel = d.car_rental_needed ? `🚗 Mietwagen in ${carCity}` : `🚗 Mietwagen ab ${carCity}`;
          return `<div class="ap-section orange">
            <div class="ap-section-header">${carLabel}</div>
            <div class="ap-section-body" style="display:flex;gap:0.5rem;flex-wrap:wrap;">
              <a class="hotel-btn expedia-navy-btn" href="${expUrl}" target="_blank" rel="noopener">Expedia</a>
              <a class="hotel-btn dc-btn" href="${dcCarBtn}" target="_blank" rel="noopener">DiscoverCars</a>
            </div>
          </div>`;
        })() : ''}
      </div>
    </div>`;
  }).join('');

  const airportNames = {};
  if (d.origin) airportNames[d.origin.airport] = d.origin.city + '/' + d.origin.country;
  (d.outbound?.suggested_airports || []).forEach(a => airportNames[a.code] = a.city);
  (d.return?.suggested_airports || []).forEach(a => airportNames[a.code] = a.city);
  const codeName = code => airportNames[code] ? `${code} (${airportNames[code]})` : code;

  const queriesHtml = (d.search_queries || []).map((q, i) => {
    const [orig, dest] = q.route.split('-');
    const dep = q.departure_date || (q.dates.match(/(\d{4}-\d{2}-\d{2})/g) || [])[0] || '';
    const ret = q.return_date || (q.dates.match(/(\d{4}-\d{2}-\d{2})/g) || [])[1] || '';
    const expediaUrl = zercyUrls.expediaFlights(orig, dest, dep, ret, q.cabin);
    return `
    <a class="query-item query-link" href="${expediaUrl}" target="_blank" rel="noopener">
      <div class="query-num">${i+1}</div>
      <div>
        <div class="query-route">${codeName(orig)} → ${codeName(dest)}</div>
        <div class="query-meta">${q.cabin} · ${q.dates} · ${q.type}</div>
      </div>
      <div class="query-search">${t(zercyLang, 'searchArrow')}</div>
    </a>`;
  }).join('');

  // Trip Summary Bar
  const allOutFlights = (d.outbound?.suggested_airports || []).flatMap(a => a.flights || []);
  const allRetFlights = (d.return?.suggested_airports || []).flatMap(a => a.flights || []);
  const cheapestOut = allOutFlights.length ? Math.min(...allOutFlights.map(f => f.price)) : null;
  const originCode = d.origin?.airport || '';
  const destCodes = (d.outbound?.suggested_airports || []).map(a => a.code).slice(0, 3);
  const retCodes = (d.return?.suggested_airports || []).map(a => a.code).slice(0, 3);
  const outDateRaw = d.outbound?.recommended_date || '';
  const retDateRaw = d.return?.recommended_date || '';
  const fmtShort = s => { if (!s) return ''; const dt = new Date(s + 'T00:00:00'); return dt.toLocaleDateString(zercyLang === 'de' ? 'de-DE' : zercyLang === 'fr' ? 'fr-FR' : zercyLang === 'es' ? 'es-ES' : 'en-US', { day: 'numeric', month: 'short' }); };
  const destDisplay = destCodes.length === 1 ? destCodes[0] : destCodes.join('/');
  const dateRange = outDateRaw ? `${fmtShort(outDateRaw)}${retDateRaw ? ' → ' + fmtShort(retDateRaw) : ''}` : '';
  const priceHtml = cheapestOut ? `<span class="tsb-dot">·</span><span class="tsb-price">${t(zercyLang, 'from') || 'ab'} €${cheapestOut}</span>` : '';
  const isOpenJaw = retCodes.length > 0 && !retCodes.every(c => destCodes.includes(c));
  const ojSub = isOpenJaw ? `<div class="tsb-sub">Open-Jaw: ${originCode}→${destCodes[0] || ''}${retCodes[0] ? ', ' + retCodes[0] + '→' + originCode : ''}</div>` : '';

  const tripSummaryBar = `<div class="trip-summary-bar">
    <div class="tsb-main">
      <span>✈ ${originCode} → ${destDisplay}</span>
      ${dateRange ? `<span class="tsb-dot">·</span><span>${dateRange}</span>` : ''}
      ${d.cabin ? `<span class="tsb-dot">·</span><span>${d.cabin}</span>` : ''}
      ${priceHtml}
    </div>
    ${ojSub}
  </div>`;

  // Flight Table
  const flightTableHtml = buildFlightTableHtml(d, id);
  const hasTable = flightTableHtml.length > 0;
  const toggleHtml = hasTable ? `<div class="view-toggle">
    <button class="view-toggle-btn active" data-view="card" onclick="toggleFlightView('card',${id})">🗂 Cards</button>
    <button class="view-toggle-btn" data-view="table" onclick="toggleFlightView('table',${id})">📊 Table</button>
  </div>` : '';

  return `
    ${tripSummaryBar}
    <div class="summary-banner">
      <div class="icon">🌍</div>
      <div>
        <div class="label">${t(zercyLang, 'zercyUnderstood')}</div>
        <div class="text">${d.summary}</div>
      </div>
    </div>
    ${toggleHtml}
    <div class="grid-2">
      <div class="card">
        <div class="card-header">
          <div class="card-icon">🛫</div>
          <div class="card-title">${t(zercyLang, 'outbound')}</div>
        </div>
        <div class="info-row"><span class="key">${t(zercyLang, 'from')}</span><span class="val">${d.origin ? d.origin.city + ' (' + d.origin.airport + ')' : t(zercyLang, 'notSpecified')}</span></div>
        <div class="info-row"><span class="key">${t(zercyLang, 'cabin')}</span><span class="val">${d.cabin}</span></div>
        <div class="info-row"><span class="key">${t(zercyLang, 'recommended')}</span><span class="val">${d.outbound?.recommended_date || d.outbound?.latest_date || t(zercyLang, 'flexibility')}</span></div>
        <div class="info-row"><span class="key">${t(zercyLang, 'dateTip')}</span><span class="val">${d.outbound?.date_reasoning || ''}</span></div>
        <div class="info-row"><span class="key">${t(zercyLang, 'nonstop')}</span><span class="val">${d.outbound?.nonstop_preferred ? t(zercyLang, 'preferred') : t(zercyLang, 'flexibility')}</span></div>
        <div class="airports-section">
          <div class="airports-label">${t(zercyLang, 'bestAirportsNear')} "${d.outbound?.destination_intent || ''}"</div>
          ${airportHtml(d.outbound?.suggested_airports || [], false)}
        </div>
      </div>
      <div class="card">
        <div class="card-header">
          <div class="card-icon">🛬</div>
          <div class="card-title">${t(zercyLang, 'returnTrip')}</div>
        </div>
        <div class="info-row"><span class="key">${t(zercyLang, 'timeframe')}</span><span class="val">${d.return?.timeframe || t(zercyLang, 'flexibility')}</span></div>
        <div class="info-row"><span class="key">${t(zercyLang, 'recommended')}</span><span class="val">${d.return?.recommended_date || t(zercyLang, 'flexibility')}</span></div>
        <div class="info-row"><span class="key">${t(zercyLang, 'flexibility')}</span><span class="val">${d.return?.flexibility || 'open'}</span></div>
        <div class="info-row"><span class="key">${t(zercyLang, 'nonstop')}</span><span class="val">${d.return?.nonstop_preferred ? t(zercyLang, 'preferred') : t(zercyLang, 'flexibility')}</span></div>
        <div class="airports-section">
          <div class="airports-label">${t(zercyLang, 'bestAirportsFrom')} "${d.return?.origin_intent || 'destination'}"</div>
          ${airportHtml(d.return?.suggested_airports || [], true)}
        </div>
      </div>
    </div>
    ${flightTableHtml}
    ${hotelDest ? `
      <div class="ideas-trigger-card" id="ideas-trigger-${id}">
        <div class="ideas-trigger-title">${{ de:`Was kann man in ${hotelDest} machen?`, en:`What can I do in ${hotelDest}?`, fr:`Que faire à ${hotelDest} ?`, es:`¿Qué hacer en ${hotelDest}?`, nl:`Wat kun je doen in ${hotelDest}?`, it:`Cosa fare a ${hotelDest}?`, pt:`O que fazer em ${hotelDest}?` }[zercyLang] || `What can I do in ${hotelDest}?`}</div>
        <div class="ideas-trigger-sub">${{ de:'Zercys Ideen für jeden Tag', en:"Zercy's ideas for every day", fr:'Les idées de Zercy pour chaque jour', es:'Ideas de Zercy para cada día', nl:"Zercy's ideeën voor elke dag", it:'Le idee di Zercy per ogni giorno', pt:'Ideias do Zercy para cada dia' }[zercyLang] || "Zercy's ideas for every day"}</div>
        <button class="ideas-trigger-btn" onclick="generateIdeas(${id}, '${(hotelDest || '').replace(/'/g,"\\'")}', '${hotelCheckin || ''}', '${hotelCheckout || ''}')">✨ ${{ de:'Ideen anzeigen', en:'Show ideas', fr:'Voir les idées', es:'Ver ideas', nl:'Toon ideeën', it:'Mostra idee', pt:'Ver ideias' }[zercyLang] || 'Show ideas'}</button>
      </div>
      <div class="ideas-container" id="ideas-${id}" style="display:none;"></div>
    ` : ''}
    ${turnCount > 1 ? `<div style="text-align:right; margin-top:-0.3rem;">
      <a href="#" onclick="scrollToTop(document.getElementById('plan-turn-1'));return false;" style="font-size:0.75rem;color:#94a3b8;text-decoration:none;font-weight:600;">${t(zercyLang, 'backToResults')}</a>
    </div>` : ''}
    <div class="refinement-section">
      <div class="refinement-label">${t(zercyLang, 'refineSearch')}</div>
      <div class="answer-chips" style="margin-bottom:0.8rem;">
        ${(t(zercyLang, 'refineChips') || []).map(chip =>
          `<button class="answer-chip" onclick="this.classList.toggle('selected')">${chip}</button>`
        ).join('')}
      </div>
      <div class="followup-row">
        <textarea id="followup-${id}" placeholder="${t(zercyLang, 'refinePlaceholder')}" rows="2"></textarea>
        <button class="tell-zercy-btn" onclick="tellZercy('followup-${id}', ${id})">${t(zercyLang, 'tellZercyBtn')}</button>
      </div>
      <div class="zercy-ack-bubbles" id="zercy-ack-${id}"></div>
      <div class="search-divider">${t(zercyLang, 'searchDivider')}</div>
      <button class="research-btn" onclick="parseIntent(lastIntent)">${t(zercyLang, 'researchBtn')}</button>
    </div>
    ${extraComponentsHtml(d)}
  `;
}

function showChatWidget(destination, checkin, checkout, tripData, insights) {
  chatDestination = destination || '';
  chatCheckin = checkin || '';
  chatCheckout = checkout || '';
  if (tripData) chatTripContext = tripData;
  const wrapper = document.getElementById('zercyFloatWrapper');
  if (wrapper) wrapper.style.display = 'flex';
  const eyebrow = document.getElementById('floatEyebrow');
  if (eyebrow) eyebrow.textContent = t(zercyLang, 'floatEyebrow');
  if (insights && insights.length) {
    insights.forEach(i => { if (i && !allInsights.includes(i)) allInsights.push(i); });
    const insightsList = document.getElementById('float-insights-list');
    const insightsSec = document.getElementById('float-insights-section');
    if (insightsList) {
      insightsList.innerHTML = allInsights.map(i =>
        `<div class="float-insight-item"><span class="float-insight-bullet">💡</span><span>${i}</span></div>`
      ).join('');
    }
    if (insightsSec) insightsSec.style.display = 'block';
  }
  const btnLabel = document.getElementById('floatBtnLabel');
  if (btnLabel) {
    const hasInsights = allInsights.length > 0;
    if (destination && hasInsights) {
      btnLabel.textContent = `${t(zercyLang, 'floatKnowsMore')} ${destination}`;
    } else {
      btnLabel.textContent = `${t(zercyLang, 'floatHotelsLabel')}${destination ? ' — ' + destination : ''}`;
    }
  }
  const title = document.getElementById('floatPanelTitle');
  const ctx = document.getElementById('floatPanelContext');
  if (title) title.textContent = t(zercyLang, 'chatHeader');
  if (ctx) ctx.textContent = destination
    ? `${t(zercyLang, 'floatCtxLabel')} ${destination} ${t(zercyLang, 'floatCtxSuffix')}`
    : t(zercyLang, 'chatSub');
}

function toggleFloatPanel() {
  const panel = document.getElementById('zercyFloatPanel');
  if (!panel) return;
  const isOpen = panel.classList.contains('open');
  if (isOpen) {
    panel.classList.remove('open');
  } else {
    panel.classList.add('open');
    const chips = t(zercyLang, 'chatChips');
    const container = document.getElementById('chat-suggestions');
    if (container && Array.isArray(chips)) {
      container.innerHTML = chips.map(chip =>
        `<span class="chat-chip" onclick="sendChatSuggestion(this.innerText)">${chip}</span>`
      ).join('');
    }
    setTimeout(() => document.getElementById('chat-input')?.focus(), 150);
  }
}

function addChatMessage(text, role) {
  const el = document.getElementById('chat-messages');
  const msg = document.createElement('div');
  msg.className = 'chat-msg ' + role;
  msg.innerHTML = text.replace(/\n/g, '<br>');
  el.appendChild(msg);
  el.scrollTop = el.scrollHeight;
  return msg;
}

async function sendChat() {
  const input = document.getElementById('chat-input');
  const message = input.value.trim();
  if (!message) return;
  input.value = '';
  addChatMessage(message, 'user');
  const typing = addChatMessage(t(zercyLang, 'chatTyping'), 'zercy typing');
  try {
    const res = await fetch('/api/chat', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        message, history: chatHistory, uiLanguage: zercyLang,
        destination: chatDestination, checkin: chatCheckin, checkout: chatCheckout,
        tripContext: chatTripContext ? {
          origin: chatTripContext.origin,
          destination_intent: chatTripContext.outbound?.destination_intent,
          cabin: chatTripContext.cabin,
          outbound_date: chatTripContext.outbound?.recommended_date,
          return_date: chatTripContext.return?.recommended_date,
          summary: chatTripContext.summary
        } : null,
        planContext: {
          userIntent: lastIntent,
          narrative: currentPlanData?.narrative,
          smartInsights: currentPlanData?.smart_insights,
          understood: currentPlanData?.understood,
          planNote: currentPlanData?.zercy_plan_note
        }
      })
    });
    const data = await safeApiResponse(res);
    typing.remove();
    addChatMessage(data.reply, 'zercy');
    chatHistory.push({ role: 'user', content: message });
    chatHistory.push({ role: 'assistant', content: data.reply });
  } catch {
    typing.remove();
    addChatMessage(t(zercyLang, 'chatError'), 'zercy');
  }
}

function sendChatSuggestion(text) {
  document.getElementById('chat-input').value = text;
  sendChat();
}

async function tellZercy(inputId, turnId) {
  const el = document.getElementById(inputId);
  if (!el) return;
  const section = el.closest('.refinement-section');
  const selectedChips = [...section.querySelectorAll('.answer-chip.selected')].map(c => c.textContent);
  const typedText = el.value.trim();
  const allInput = [...selectedChips, typedText].filter(Boolean).join(', ');
  if (!allInput) return;
  lastIntent = lastIntent + '. Additional: ' + allInput;
  zercyAdditions.push(allInput);
  el.value = '';
  section.querySelectorAll('.answer-chip.selected').forEach(c => c.classList.remove('selected'));
  const bubbles = document.getElementById('zercy-ack-' + turnId);
  const typing = document.createElement('div');
  typing.className = 'zercy-ack-bubble typing';
  typing.innerHTML = `<div class="reply-orb"></div><span>${t(zercyLang, 'chatTyping')}</span>`;
  bubbles.appendChild(typing);
  bubbles.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  try {
    const res = await fetch('/api/think', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ intent: zercyOriginalIntent, mode: 'respond', context: lastIntent, addition: allInput, uiLanguage: zercyLang })
    });
    const data = await safeApiResponse(res);
    typing.remove();
    const bubble = document.createElement('div');
    bubble.className = 'zercy-ack-bubble';
    bubble.innerHTML = `<div class="reply-orb"></div><span>${data.reply || '...'}</span>`;
    bubbles.appendChild(bubble);
    bubbles.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  } catch { typing.remove(); }
}

function newSearch() {
  document.getElementById('conversation').innerHTML = '';
  document.getElementById('intent').value = '';
  document.getElementById('newSearchBtn').style.display = 'none';
  const heroEl = document.getElementById('hero');
  if (heroEl) heroEl.classList.remove('compact');
  const wrapper = document.getElementById('zercy-results-wrapper');
  if (wrapper) wrapper.style.display = 'none';
  const floatBtn = document.getElementById('zercyFloatWrapper');
  if (floatBtn) floatBtn.style.display = 'none';
  const floatPanel = document.getElementById('zercyFloatPanel');
  if (floatPanel) floatPanel.classList.remove('open');
  document.getElementById('chat-messages').innerHTML = '';
  chatHistory = [];
  turnCount = 0;
  lastIntent = '';
  zercyAnswers = {};
  zercyAdditions = [];
  zercyTextAnswers = {};
  zercyOriginalIntent = '';
  currentPlanData = null;
  zercyLang = window.__ZERCY_LANG__ || 'de';
  allInsights = [];
  const insightsSec = document.getElementById('float-insights-section');
  const insightsList = document.getElementById('float-insights-list');
  if (insightsSec) insightsSec.style.display = 'none';
  if (insightsList) insightsList.innerHTML = '';
  applyLanguageToStaticUI(window.__ZERCY_LANG__ || 'de');
  window.scrollTo({ top: 0, behavior: 'smooth' });
  setTimeout(() => document.getElementById('intent')?.focus(), 400);
}

// ── TYPEWRITER + AVATAR ANIMATION ──
(function() {
  const phrases = window.__ZERCY_PHRASES__ || ['Just type your destination...'];
  let phraseIndex = 0, charIndex = 0, isDeleting = false, timer = null, stopped = false;
  function typeStep() {
    if (stopped) return;
    const input = document.getElementById('intent');
    if (!input || input.value !== '') return;
    const current = phrases[phraseIndex];
    if (!isDeleting) {
      charIndex++;
      input.placeholder = current.substring(0, charIndex);
      if (charIndex === current.length) { timer = setTimeout(() => { isDeleting = true; typeStep(); }, 2200); return; }
      timer = setTimeout(typeStep, 55);
    } else {
      charIndex--;
      input.placeholder = current.substring(0, charIndex);
      if (charIndex === 0) { isDeleting = false; phraseIndex = (phraseIndex + 1) % phrases.length; timer = setTimeout(typeStep, 400); return; }
      timer = setTimeout(typeStep, 28);
    }
  }
  setTimeout(typeStep, 1200);
  window.addEventListener('load', () => {
    const input = document.getElementById('intent');
    if (input) {
      input.addEventListener('focus', () => { stopped = true; clearTimeout(timer); input.placeholder = ''; });
      input.addEventListener('input', () => {
        const btn = document.getElementById('searchBtn');
        if (!btn) return;
        if (input.value.trim().length > 0) { btn.classList.add('btn-pulse'); }
        else { btn.classList.remove('btn-pulse'); }
      });
    }
    // Observe new turn-results for hotel price badges (live load via /api/hotel-prices)
    const chatHost = document.querySelector('.chat-results') || document.body;
    if (chatHost && typeof loadHotelPrices === 'function') {
      const debounced = (() => { let t; return () => { clearTimeout(t); t = setTimeout(() => loadHotelPrices(document), 250); }; })();
      new MutationObserver(debounced).observe(chatHost, { childList: true, subtree: true });
    }
  });
})();

