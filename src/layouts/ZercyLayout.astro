  .orb-sparkle { position: absolute; width: 5px; height: 5px; background: #f97316; border-radius: 50%; animation: sparkle 1s ease-in-out infinite alternate; }
  .orb-sparkle.s1 { top: -4px; left: 18px; animation-delay: 0s; }
