function buildCarOnlyHtml(d) {
  const lang = zercyLang;
  const pickup = d.pickup || {};
  const dropoff = d.dropoff || {};
  // fmtDate: parse YYYY-MM-DD as local date (avoids UTC-1-day-offset bug in Europe), fallback to raw string
  const fmtDate = s => { if (!s) return ''; const p = s.match(/^(\d{4})-(\d{2})-(\d{2})$/); if (!p) return s; const [,y,mo,dy] = p.map(Number); return new Date(y,mo-1,dy).toLocaleDateString(lang==='de'?'de-DE':'en-GB',{day:'numeric',month:'long',year:'numeric'}); };
  // fmtRC: YYYY-MM-DD for Rentalcars (ISO format — DD/MM/YYYY causes NaN crash on their side)
  const fmtRC = s => s?.match(/^\d{4}-\d{2}-\d{2}$/) ? s : '';
  // fmtExp: MM/DD/YYYY for Expedia (US date format)
  const fmtExp = s => { if (!s) return ''; const p = s.match(/^(\d{4})-(\d{2})-(\d{2})$/); if (!p) return ''; return `${p[2]}/${p[3]}/${p[1]}`; };
  const rcAddr = s => { const m = (s||'').match(/\(([A-Z]{3})\)/); return m ? m[1] : (s||'').replace(/\(.*?\)/g,'').trim(); };
  const puAddr = rcAddr(pickup.location||pickup.city||'');
  const doAddr = rcAddr(dropoff.location||dropoff.city||pickup.city||'');
  // Rentalcars: city name only (IATA breaks it), no addrTo (one-way checkbox can't be set via URL)
  const rcUrl = `https://www.rentalcars.com/SearchResults.do?addrFrom=${encodeURIComponent(pickup.city||puAddr)}&dateFrom=${fmtRC(pickup.date)}&timeFrom=10:00&dateTo=${fmtRC(dropoff.date)}&timeTo=10:00&driverAge=30`;
  // Kayak: path-based, works reliably
  const kayakUrl = `https://www.kayak.com/cars/${encodeURIComponent(pickup.city||'')}/${pickup.date||''}/${dropoff.date||''}`;
  // Expedia: US date format MM/DD/YYYY
  const expediaUrl = `https://www.expedia.com/carsearch?addrFrom=${encodeURIComponent(pickup.city||'')}&dateFrom=${encodeURIComponent(fmtExp(pickup.date))}&timeFrom=10:00&dateTo=${encodeURIComponent(fmtExp(dropoff.date))}&timeTo=10:00`;
  // EconomyCarRentals: YYYY-MM-DD format
  const econUrl = `https://www.economycarrentals.com/en/results/?pickup=${encodeURIComponent(pickup.city||'')}&dropoff=${encodeURIComponent(dropoff.city||pickup.city||'')}&date1=${pickup.date||''}&date2=${dropoff.date||''}`;
  return `
    <div class="summary-banner">
      <div class="icon">🚗</div>
      <div>
        <div class="label">${t(lang, 'zercyUnderstood')}</div>
        <div class="text">${d.summary}</div>
      </div>
    </div>
    <div class="card" style="margin-bottom:1rem;">
      <div class="card-header">
        <div class="card-icon">🚗</div>
        <div class="card-title">Mietwagen</div>
      </div>
      <div class="info-row"><span class="key">📍 Abholung</span><span class="val">${pickup.location || pickup.city || ''}</span></div>
      <div class="info-row"><span class="key">📅 Von</span><span class="val">${fmtDate(pickup.date)}</span></div>
      <div class="info-row"><span class="key">📅 Bis</span><span class="val">${fmtDate(dropoff.date)}</span></div>
      ${dropoff.location && dropoff.location !== pickup.location ? `<div class="info-row"><span class="key">📍 Rückgabe</span><span class="val">${dropoff.location}</span></div>` : ''}
      <div class="ap-section orange" style="margin-top:0.8rem;">
        <div class="ap-section-header">🚗 Mietwagen buchen</div>
        <div class="ap-section-body" style="display:flex;gap:0.5rem;flex-wrap:wrap;">
          <a class="hotel-btn booking-btn" href="${rcUrl}" target="_blank" rel="noopener">Rentalcars.com</a>
          <a class="hotel-btn expedia-btn" href="${kayakUrl}" target="_blank" rel="noopener">Kayak</a>
          <a class="hotel-btn" style="background:#003087;color:#fff;" href="${expediaUrl}" target="_blank" rel="noopener">Expedia</a>
          <a class="hotel-btn" style="background:#2e7d32;color:#fff;" href="${econUrl}" target="_blank" rel="noopener">EconomyCarRentals</a>
        </div>
      </div>
    </div>
  `;
}

function buildResultsHtml(d, id) {
  if (d.car_only) return buildCarOnlyHtml(d);

  const hotelDest = d.outbound?.destination_intent || '';
  const hotelCheckin = d.outbound?.recommended_date || '';
  const hotelCheckout = d.return?.recommended_date || '';
  const fmtExpedia = s => s ? s.replace(/(\d{4})-(\d{2})-(\d{2})/, '$2/$3/$1') : '';

  const airportHtml = (airports, isReturn = false) => airports.map(a => {
    const gt = a.ground_transport;
    const groundHtml = gt ? (() => {
      const dest = gt.destination || a.city;
      const distLabel = gt.distance_km ? ` · ${gt.distance_km} km` : '';
      const header = isReturn ? `🚗 ${dest} → ${a.code}${distLabel}` : `🚗 ${a.code} → ${dest}${distLabel}`;
      const mapsOrigin = isReturn ? encodeURIComponent(dest) : encodeURIComponent(a.city + ' Airport');
      const mapsDest = isReturn ? encodeURIComponent(a.city + ' Airport') : encodeURIComponent(dest);
      const mapsUrl = `https://www.google.com/maps/dir/?api=1&origin=${mapsOrigin}&destination=${mapsDest}&travelmode=transit`;
      return `<div class="ap-section green">
        <div class="ap-section-header">${header}</div>
        <div class="ap-section-body ground-btn-row">
          <a class="ground-app-btn maps-btn" href="${mapsUrl}" target="_blank" rel="noopener">🗺 Google Maps ↗</a>
        </div>
      </div>`;
    })() : '';

    return `
    <div class="airport-item">
      <div class="airport-code">${a.code}</div>
      <div style="flex:1">
        <div class="airport-city">${a.city}</div>
        <div class="airport-reason">${a.reason}</div>
        ${(() => {
          const origin = d.origin?.airport || '';
          const outDate = d.outbound?.recommended_date || '';
          const retDate = d.return?.recommended_date || '';
          const leg1 = isReturn ? a.code : origin;
          const leg2 = isReturn ? origin : a.code;
          const fmtE = s => s ? s.replace(/(\d{4})-(\d{2})-(\d{2})/, '$2/$3/$1') : '';
          const cabinE = { economy: 'coach', business: 'business', first: 'first' }[d.cabin?.toLowerCase()] || 'coach';
          const flightDate = isReturn ? retDate : outDate;
          const fromCity = isReturn ? (a.city || leg1) : (d.origin?.city || leg1);
          const toCity = isReturn ? (d.origin?.city || leg2) : (a.city || leg2);
          const dateStr = flightDate ? new Date(flightDate).toLocaleDateString('de-DE', { month: 'long', day: 'numeric', year: 'numeric' }) : '';
          const gflQuery = `flights from ${fromCity} to ${toCity}${dateStr ? ' on ' + dateStr : ''}`;
          const gflUrl = `https://www.google.com/travel/flights?q=${encodeURIComponent(gflQuery)}`;
          const expUrl = retDate && !isReturn
            ? `https://www.expedia.com/Flights-Search?trip=roundtrip&leg1=from:${leg1},to:${leg2},departure:${fmtE(outDate)}TANYT&leg2=from:${leg2},to:${leg1},departure:${fmtE(retDate)}TANYT&passengers=adults:1&options=cabinclass:${cabinE}&mode=search`
            : `https://www.expedia.com/Flights-Search?trip=oneway&leg1=from:${leg1},to:${leg2},departure:${fmtE(flightDate)}TANYT&passengers=adults:1&options=cabinclass:${cabinE}&mode=search`;
          const flightHeader = `✈ ${leg1} → ${leg2}`;

          if (a.isRoundtripSameAirport) {
            return `<div class="ap-section blue">
              <div class="ap-section-header">${flightHeader}</div>
              <div class="ap-section-body">
                <div style="font-size:0.78rem;color:#94a3b8;padding:0.2rem 0 0.4rem;">Im Roundtrip-Preis bereits enthalten.</div>
                <div class="flight-fallback-row">
                  <a class="flight-book-btn gfl-btn" href="${gflUrl}" target="_blank" rel="noopener">🔍 Google Flights ↗</a>
                  <a class="flight-book-btn exp-btn" href="${expUrl}" target="_blank" rel="noopener">🔍 Expedia ↗</a>
                </div>
              </div>
            </div>`;
          }

          if (a.flights && a.flights.length > 0) {
            return `<div class="ap-section blue">
              <div class="ap-section-header">${flightHeader}</div>
              <div class="ap-section-body">
                <div class="flight-cards">
                  ${a.flights.map(f => `
                    <div class="flight-card">
                      <div class="flight-card-top">
                        <span class="flight-airline">✈ ${f.airline}</span>
                        <span class="flight-price">€${f.price}</span>
                      </div>
                      <div class="flight-card-bottom">
                        ${f.departure ? `<span>${f.departure}</span><span>→</span><span>${f.arrival}</span><span>·</span>` : ''}
                        <span>${Math.floor(f.duration/60)}h${f.duration%60 ? f.duration%60+'m' : ''}</span>
                        <span>·</span>
                        <span class="${f.stops === 0 ? 'flight-nonstop' : ''}">${f.stops === 0 ? 'nonstop' : f.stops + ' stop'}</span>
                      </div>
                      <div class="flight-book-row">
                        <a class="flight-book-btn gfl-btn" href="${gflUrl}" target="_blank" rel="noopener">Google Flights ↗</a>
                        <a class="flight-book-btn exp-btn" href="${expUrl}" target="_blank" rel="noopener">Expedia ↗</a>
                      </div>
                    </div>
                  `).join('')}
                </div>
              </div>
            </div>`;
          } else {
            return `<div class="ap-section blue">
              <div class="ap-section-header">${flightHeader}</div>
              <div class="ap-section-body">
                <div style="font-size:0.75rem;color:#94a3b8;margin-bottom:0.4rem;">Keine Live-Preise — direkt suchen:</div>
                <div class="flight-fallback-row">
                  <a class="flight-book-btn gfl-btn" href="${gflUrl}" target="_blank" rel="noopener">🔍 Google Flights ↗</a>
                  <a class="flight-book-btn exp-btn" href="${expUrl}" target="_blank" rel="noopener">🔍 Expedia ↗</a>
                </div>
              </div>
            </div>`;
          }
        })()}
        ${groundHtml}
        ${!isReturn && hotelDest ? (() => {
          const cleanDest = gt?.destination || hotelDest;
          const dest = encodeURIComponent(cleanDest);
          const bookingUrl = `https://www.booking.com/searchresults.html?ss=${dest}${hotelCheckin ? `&checkin=${hotelCheckin}` : ''}${hotelCheckout ? `&checkout=${hotelCheckout}` : ''}&group_adults=2&no_rooms=1`;
          const expediaUrl = `https://www.expedia.com/Hotel-Search?destination=${dest}${hotelCheckin ? `&startDate=${fmtExpedia(hotelCheckin)}` : ''}${hotelCheckout ? `&endDate=${fmtExpedia(hotelCheckout)}` : ''}&adults=2`;
          return `<div class="ap-section purple">
            <div class="ap-section-header">🏨 Hotels in ${cleanDest}</div>
            <div class="ap-section-body">
              <a class="hotel-btn booking-btn" href="${bookingUrl}" target="_blank" rel="noopener">Booking.com</a>
              <a class="hotel-btn expedia-btn" href="${expediaUrl}" target="_blank" rel="noopener">Expedia</a>
            </div>
          </div>`;
        })() : ''}
        ${!isReturn && hotelCheckin && hotelCheckout ? (() => {
          // Use car_rental city from parse.js if available, else fall back to airport city
          const carCity = d.car_rental?.pickup_city || a.city || '';
          const carPickup = d.car_rental?.pickup_date || hotelCheckin;
          const carDropoff = d.car_rental?.dropoff_date || hotelCheckout;
          // Rentalcars.com requires YYYY-MM-DD (DD/MM/YYYY causes NaN crash)
          const pickupLoc = encodeURIComponent(carCity + ' Airport');
          const rcUrl = `https://www.rentalcars.com/SearchResults.do?addrFrom=${encodeURIComponent(carCity)}&dateFrom=${carPickup}&timeFrom=10:00&dateTo=${carDropoff}&timeTo=10:00&driverAge=30`;
          const kayakUrl = `https://www.kayak.com/cars/${encodeURIComponent(carCity)}/${carPickup}/${carDropoff}`;
          const fmtExp = s => { if (!s) return ''; const p = s.match(/^(\d{4})-(\d{2})-(\d{2})$/); if (!p) return ''; return `${p[2]}/${p[3]}/${p[1]}`; };
          const expUrl = `https://www.expedia.com/carsearch?addrFrom=${encodeURIComponent(carCity)}&dateFrom=${encodeURIComponent(fmtExp(carPickup))}&timeFrom=10:00&dateTo=${encodeURIComponent(fmtExp(carDropoff))}&timeTo=10:00`;
          const carLabel = d.car_rental_needed ? `🚗 Mietwagen in ${carCity}` : `🚗 Mietwagen ab ${carCity}`;
          return `<div class="ap-section orange">
            <div class="ap-section-header">${carLabel}</div>
            <div class="ap-section-body" style="display:flex;gap:0.5rem;flex-wrap:wrap;">
              <a class="hotel-btn booking-btn" href="${rcUrl}" target="_blank" rel="noopener">Rentalcars.com</a>
              <a class="hotel-btn expedia-btn" href="${kayakUrl}" target="_blank" rel="noopener">Kayak</a>
              <a class="hotel-btn" style="background:#003087;color:#fff;" href="${expUrl}" target="_blank" rel="noopener">Expedia</a>
            </div>
          </div>`;
        })() : ''}
      </div>
    </div>`;
  }).join('');

  const airportNames = {};
  if (d.origin) airportNames[d.origin.airport] = d.origin.city + '/' + d.origin.country;
  (d.outbound?.suggested_airports || []).forEach(a => airportNames[a.code] = a.city);
  (d.return?.suggested_airports || []).forEach(a => airportNames[a.code] = a.city);
  const codeName = code => airportNames[code] ? `${code} (${airportNames[code]})` : code;

  const queriesHtml = (d.search_queries || []).map((q, i) => {
    const [orig, dest] = q.route.split('-');
    const dep = q.departure_date || (q.dates.match(/(\d{4}-\d{2}-\d{2})/g) || [])[0] || '';
    const ret = q.return_date || (q.dates.match(/(\d{4}-\d{2}-\d{2})/g) || [])[1] || '';
    const cabinExpedia = { economy:'coach', business:'business', first:'first', 'premium economy':'premiumcoach' };
    const expCabin = cabinExpedia[(q.cabin || 'economy').toLowerCase()] || 'coach';
    const fmtDate = s => s ? s.replace(/(\d{4})-(\d{2})-(\d{2})/, '$2/$3/$1') : '';
    const expediaUrl = ret
      ? `https://www.expedia.com/Flights-Search?trip=roundtrip&leg1=from:${orig},to:${dest},departure:${fmtDate(dep)}TANYT&leg2=from:${dest},to:${orig},departure:${fmtDate(ret)}TANYT&passengers=adults:1&options=cabinclass:${expCabin}&mode=search`
      : `https://www.expedia.com/Flights-Search?trip=oneway&leg1=from:${orig},to:${dest},departure:${fmtDate(dep)}TANYT&passengers=adults:1&options=cabinclass:${expCabin}&mode=search`;
    return `
    <a class="query-item query-link" href="${expediaUrl}" target="_blank" rel="noopener">
      <div class="query-num">${i+1}</div>
      <div>
        <div class="query-route">${codeName(orig)} → ${codeName(dest)}</div>
        <div class="query-meta">${q.cabin} · ${q.dates} · ${q.type}</div>
      </div>
      <div class="query-search">${t(zercyLang, 'searchArrow')}</div>
    </a>`;
  }).join('');

  return `
    <div class="summary-banner">
      <div class="icon">🌍</div>
      <div>
        <div class="label">${t(zercyLang, 'zercyUnderstood')}</div>
        <div class="text">${d.summary}</div>
      </div>
    </div>
    <div class="grid-2">
      <div class="card">
        <div class="card-header">
          <div class="card-icon">🛫</div>
          <div class="card-title">${t(zercyLang, 'outbound')}</div>
        </div>
        <div class="info-row"><span class="key">${t(zercyLang, 'from')}</span><span class="val">${d.origin ? d.origin.city + ' (' + d.origin.airport + ')' : t(zercyLang, 'notSpecified')}</span></div>
        <div class="info-row"><span class="key">${t(zercyLang, 'cabin')}</span><span class="val">${d.cabin}</span></div>
        <div class="info-row"><span class="key">${t(zercyLang, 'recommended')}</span><span class="val">${d.outbound?.recommended_date || d.outbound?.latest_date || t(zercyLang, 'flexibility')}</span></div>
        <div class="info-row"><span class="key">${t(zercyLang, 'dateTip')}</span><span class="val">${d.outbound?.date_reasoning || ''}</span></div>
        <div class="info-row"><span class="key">${t(zercyLang, 'nonstop')}</span><span class="val">${d.outbound?.nonstop_preferred ? t(zercyLang, 'preferred') : t(zercyLang, 'flexibility')}</span></div>
        <div class="airports-section">
          <div class="airports-label">${t(zercyLang, 'bestAirportsNear')} "${d.outbound?.destination_intent || ''}"</div>
          ${airportHtml(d.outbound?.suggested_airports || [], false)}
        </div>
      </div>
      <div class="card">
        <div class="card-header">
          <div class="card-icon">🛬</div>
          <div class="card-title">${t(zercyLang, 'returnTrip')}</div>
        </div>
        <div class="info-row"><span class="key">${t(zercyLang, 'timeframe')}</span><span class="val">${d.return?.timeframe || t(zercyLang, 'flexibility')}</span></div>
        <div class="info-row"><span class="key">${t(zercyLang, 'recommended')}</span><span class="val">${d.return?.recommended_date || t(zercyLang, 'flexibility')}</span></div>
        <div class="info-row"><span class="key">${t(zercyLang, 'flexibility')}</span><span class="val">${d.return?.flexibility || 'open'}</span></div>
        <div class="info-row"><span class="key">${t(zercyLang, 'nonstop')}</span><span class="val">${d.return?.nonstop_preferred ? t(zercyLang, 'preferred') : t(zercyLang, 'flexibility')}</span></div>
        <div class="airports-section">
          <div class="airports-label">${t(zercyLang, 'bestAirportsFrom')} "${d.return?.origin_intent || 'destination'}"</div>
          ${airportHtml(d.return?.suggested_airports || [], true)}
        </div>
      </div>
    </div>
    ${turnCount > 1 ? `<div style="text-align:right; margin-top:-0.3rem;">
      <a href="#" onclick="scrollToTop(document.getElementById('plan-turn-1'));return false;" style="font-size:0.75rem;color:#94a3b8;text-decoration:none;font-weight:600;">${t(zercyLang, 'backToResults')}</a>
    </div>` : ''}
    <div class="refinement-section">
      <div class="refinement-label">${t(zercyLang, 'refineSearch')}</div>
      <div class="answer-chips" style="margin-bottom:0.8rem;">
        ${(t(zercyLang, 'refineChips') || []).map(chip =>
          `<button class="answer-chip" onclick="this.classList.toggle('selected')">${chip}</button>`
        ).join('')}
      </div>
      <div class="followup-row">
        <textarea id="followup-${id}" placeholder="${t(zercyLang, 'refinePlaceholder')}" rows="2"></textarea>
        <button class="tell-zercy-btn" onclick="tellZercy('followup-${id}', ${id})">${t(zercyLang, 'tellZercyBtn')}</button>
      </div>
      <div class="zercy-ack-bubbles" id="zercy-ack-${id}"></div>
      <div class="search-divider">${t(zercyLang, 'searchDivider')}</div>
      <button class="research-btn" onclick="parseIntent(lastIntent)">${t(zercyLang, 'researchBtn')}</button>
    </div>
  `;
}

function showChatWidget(destination, checkin, checkout, tripData, insights) {
  chatDestination = destination || '';
  chatCheckin = checkin || '';
  chatCheckout = checkout || '';
  if (tripData) chatTripContext = tripData;
  const wrapper = document.getElementById('zercyFloatWrapper');
  if (wrapper) wrapper.style.display = 'flex';
  const eyebrow = document.getElementById('floatEyebrow');
  if (eyebrow) eyebrow.textContent = t(zercyLang, 'floatEyebrow');
  if (insights && insights.length) {
    insights.forEach(i => { if (i && !allInsights.includes(i)) allInsights.push(i); });
    const insightsList = document.getElementById('float-insights-list');
    const insightsSec = document.getElementById('float-insights-section');
    if (insightsList) {
      insightsList.innerHTML = allInsights.map(i =>
        `<div class="float-insight-item"><span class="float-insight-bullet">💡</span><span>${i}</span></div>`
      ).join('');
    }
    if (insightsSec) insightsSec.style.display = 'block';
  }
  const btnLabel = document.getElementById('floatBtnLabel');
  if (btnLabel) {
    const hasInsights = allInsights.length > 0;
    if (destination && hasInsights) {
      btnLabel.textContent = `${t(zercyLang, 'floatKnowsMore')} ${destination}`;
    } else {
      btnLabel.textContent = `${t(zercyLang, 'floatHotelsLabel')}${destination ? ' — ' + destination : ''}`;
    }
  }
  const title = document.getElementById('floatPanelTitle');
  const ctx = document.getElementById('floatPanelContext');
  if (title) title.textContent = t(zercyLang, 'chatHeader');
  if (ctx) ctx.textContent = destination
    ? `${t(zercyLang, 'floatCtxLabel')} ${destination} ${t(zercyLang, 'floatCtxSuffix')}`
    : t(zercyLang, 'chatSub');
}

function toggleFloatPanel() {
  const panel = document.getElementById('zercyFloatPanel');
  if (!panel) return;
  const isOpen = panel.classList.contains('open');
  if (isOpen) {
    panel.classList.remove('open');
  } else {
    panel.classList.add('open');
    const chips = t(zercyLang, 'chatChips');
    const container = document.getElementById('chat-suggestions');
    if (container && Array.isArray(chips)) {
      container.innerHTML = chips.map(chip =>
        `<span class="chat-chip" onclick="sendChatSuggestion(this.innerText)">${chip}</span>`
      ).join('');
    }
    setTimeout(() => document.getElementById('chat-input')?.focus(), 150);
  }
}

function addChatMessage(text, role) {
  const el = document.getElementById('chat-messages');
  const msg = document.createElement('div');
  msg.className = 'chat-msg ' + role;
  msg.innerHTML = text.replace(/\n/g, '<br>');
  el.appendChild(msg);
  el.scrollTop = el.scrollHeight;
  return msg;
}

async function sendChat() {
  const input = document.getElementById('chat-input');
  const message = input.value.trim();
  if (!message) return;
  input.value = '';
  addChatMessage(message, 'user');
  const typing = addChatMessage(t(zercyLang, 'chatTyping'), 'zercy typing');
  try {
    const res = await fetch('/api/chat', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        message, history: chatHistory,
        destination: chatDestination, checkin: chatCheckin, checkout: chatCheckout,
        tripContext: chatTripContext ? {
          origin: chatTripContext.origin,
          destination_intent: chatTripContext.outbound?.destination_intent,
          cabin: chatTripContext.cabin,
          outbound_date: chatTripContext.outbound?.recommended_date,
          return_date: chatTripContext.return?.recommended_date,
          summary: chatTripContext.summary
        } : null,
        planContext: {
          userIntent: lastIntent,
          narrative: currentPlanData?.narrative,
          smartInsights: currentPlanData?.smart_insights,
          understood: currentPlanData?.understood,
          planNote: currentPlanData?.zercy_plan_note
        }
      })
    });
    const data = await res.json();
    typing.remove();
    addChatMessage(data.reply, 'zercy');
    chatHistory.push({ role: 'user', content: message });
    chatHistory.push({ role: 'assistant', content: data.reply });
  } catch {
    typing.remove();
    addChatMessage(t(zercyLang, 'chatError'), 'zercy');
  }
}

function sendChatSuggestion(text) {
  document.getElementById('chat-input').value = text;
  sendChat();
}

async function tellZercy(inputId, turnId) {
  const el = document.getElementById(inputId);
  if (!el) return;
  const section = el.closest('.refinement-section');
  const selectedChips = [...section.querySelectorAll('.answer-chip.selected')].map(c => c.textContent);
  const typedText = el.value.trim();
  const allInput = [...selectedChips, typedText].filter(Boolean).join(', ');
  if (!allInput) return;
  lastIntent = lastIntent + '. Additional: ' + allInput;
  zercyAdditions.push(allInput);
  el.value = '';
  section.querySelectorAll('.answer-chip.selected').forEach(c => c.classList.remove('selected'));
  const bubbles = document.getElementById('zercy-ack-' + turnId);
  const typing = document.createElement('div');
  typing.className = 'zercy-ack-bubble typing';
  typing.innerHTML = `<div class="reply-orb"></div><span>${t(zercyLang, 'chatTyping')}</span>`;
  bubbles.appendChild(typing);
  bubbles.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  try {
    const res = await fetch('/api/think', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ intent: zercyOriginalIntent, mode: 'respond', context: lastIntent, addition: allInput })
    });
    const data = await res.json();
    typing.remove();
    const bubble = document.createElement('div');
    bubble.className = 'zercy-ack-bubble';
    bubble.innerHTML = `<div class="reply-orb"></div><span>${data.reply || '...'}</span>`;
    bubbles.appendChild(bubble);
    bubbles.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  } catch { typing.remove(); }
}

function newSearch() {
  document.getElementById('conversation').innerHTML = '';
  document.getElementById('intent').value = '';
  document.getElementById('newSearchBtn').style.display = 'none';
  const heroEl = document.getElementById('hero');
  if (heroEl) heroEl.classList.remove('compact');
  const wrapper = document.getElementById('zercy-results-wrapper');
  if (wrapper) wrapper.style.display = 'none';
  const floatBtn = document.getElementById('zercyFloatWrapper');
  if (floatBtn) floatBtn.style.display = 'none';
  const floatPanel = document.getElementById('zercyFloatPanel');
  if (floatPanel) floatPanel.classList.remove('open');
  document.getElementById('chat-messages').innerHTML = '';
  chatHistory = [];
  turnCount = 0;
  lastIntent = '';
  zercyAnswers = {};
  zercyAdditions = [];
  zercyTextAnswers = {};
  zercyOriginalIntent = '';
  currentPlanData = null;
  zercyLang = window.__ZERCY_LANG__ || 'de';
  allInsights = [];
  const insightsSec = document.getElementById('float-insights-section');
  const insightsList = document.getElementById('float-insights-list');
  if (insightsSec) insightsSec.style.display = 'none';
  if (insightsList) insightsList.innerHTML = '';
  applyLanguageToStaticUI(window.__ZERCY_LANG__ || 'de');
  window.scrollTo({ top: 0, behavior: 'smooth' });
  setTimeout(() => document.getElementById('intent')?.focus(), 400);
}

// ── TYPEWRITER + AVATAR ANIMATION ──
(function() {
  const phrases = window.__ZERCY_PHRASES__ || ['Just type your destination...'];
  let phraseIndex = 0, charIndex = 0, isDeleting = false, timer = null, stopped = false;
  function typeStep() {
    if (stopped) return;
    const input = document.getElementById('intent');
    if (!input || input.value !== '') return;
    const current = phrases[phraseIndex];
    if (!isDeleting) {
      charIndex++;
      input.placeholder = current.substring(0, charIndex);
      if (charIndex === current.length) { timer = setTimeout(() => { isDeleting = true; typeStep(); }, 2200); return; }
      timer = setTimeout(typeStep, 55);
    } else {
      charIndex--;
      input.placeholder = current.substring(0, charIndex);
      if (charIndex === 0) { isDeleting = false; phraseIndex = (phraseIndex + 1) % phrases.length; timer = setTimeout(typeStep, 400); return; }
      timer = setTimeout(typeStep, 28);
    }
  }
  setTimeout(typeStep, 1200);
  window.addEventListener('load', () => {
    const input = document.getElementById('intent');
    if (input) {
      input.addEventListener('focus', () => { stopped = true; clearTimeout(timer); input.placeholder = ''; });
      input.addEventListener('input', () => {
        const btn = document.getElementById('searchBtn');
        if (!btn) return;
        if (input.value.trim().length > 0) { btn.classList.add('btn-pulse'); }
        else { btn.classList.remove('btn-pulse'); }
      });
    }
  });
})();

