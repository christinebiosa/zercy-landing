// Live hotel price — single "from €X/night" badge in the section header.
// Uses the cheapest aggregated rate from SerpAPI Google Hotels (which is the
// honest floor price for the city + dates), not per-OTA values which are misleading.
const __hotelPriceCache = {};
function findPriceBadge(container) {
  // Header is the previousElementSibling for .ap-section-body inside .ap-section,
  // or it lives in .card-header → .card-title for hotelOnlyHtml. The badge span
  // is .hotel-price-from in either case.
  const parent = container.parentElement;
  if (!parent) return null;
  return parent.querySelector('.hotel-price-from');
}
async function loadHotelPrices(root) {
  const scope = root || document;
  const containers = scope.querySelectorAll('[data-hotel-prices]:not([data-hp-loaded])');
  for (const c of containers) {
    c.setAttribute('data-hp-loaded', '1');
    const dest = c.getAttribute('data-hotel-dest');
    const ci = c.getAttribute('data-hotel-ci') || '';
    const co = c.getAttribute('data-hotel-co') || '';
    if (!dest) continue;
    const badge = findPriceBadge(c);
    if (badge) {
      badge.classList.add('loading');
      badge.textContent = '…';
    }
    const key = dest + '|' + ci + '|' + co;
    try {
      let data = __hotelPriceCache[key];
      if (!data) {
        const res = await fetch('/api/hotel-prices', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ destination: dest, checkin: ci, checkout: co })
        });
        data = await res.json();
        __hotelPriceCache[key] = data;
      }
      const prices = data.prices || {};
      const vals = Object.values(prices).filter(v => typeof v === 'number' && v > 0);
      if (badge) {
        if (vals.length === 0) {
          badge.textContent = '';
          badge.classList.remove('loading');
        } else {
          const minVal = Math.min(...vals);
          const label = { de:'ab €' + minVal + '/Nacht', en:'from €' + minVal + '/night', fr:'dès €' + minVal + '/nuit', es:'desde €' + minVal + '/noche', nl:'vanaf €' + minVal + '/nacht', it:'da €' + minVal + '/notte', pt:'desde €' + minVal + '/noite' }[zercyLang] || ('from €' + minVal + '/night');
          badge.textContent = label;
          badge.classList.remove('loading');
        }
      }
    } catch (e) {
      if (badge) { badge.textContent = ''; badge.classList.remove('loading'); }
    }
  }
}

