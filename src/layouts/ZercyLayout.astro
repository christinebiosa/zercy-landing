  .orb-sparkle.s3 { bottom: -3px; left: 10px; animation-delay: 0.6s; }
  @keyframes sparkle { 0% { opacity: 0.3; transform: scale(0.6); } 100% { opacity: 1; transform: scale(1.3); } }

