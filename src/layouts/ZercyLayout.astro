function scrollToTop(el) {
  if (!el) return;
  const navH = document.querySelector('nav')?.offsetHeight || 64;
  const y = el.getBoundingClientRect().top + window.scrollY - navH - 16;
  window.scrollTo({ top: y, behavior: 'smooth' });
}

