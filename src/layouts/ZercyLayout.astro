// ============================================================
// ZERCY URL BUILDERS — SINGLE SOURCE OF TRUTH
// Bei Änderungen an Deep-Link-Formaten NUR hier anfassen.
// Jede URL-Funktion nimmt rohe Werte, liefert fertige URL zurück.
// Datum-Erwartung: immer YYYY-MM-DD rein; jede Funktion formatiert intern korrekt.
// ============================================================
const zercyUrls = {
  _fmtExpediaFlightDate(s) { return s ? s.replace(/(\d{4})-(\d{2})-(\d{2})/, '$2/$3/$1') : ''; },
  _expediaCabin(cabin) { return ({economy:'coach', business:'business', first:'first'})[(cabin||'').toLowerCase()] || 'coach'; },

  googleFlights(origin, dest, outDate, retDate) {
    // Query-Format ist zuverlässiger als das Hash-Format: Google parst "flights from X to Y on DATE"
    // und setzt Datum + Route korrekt. Hash-Format #flt= übernimmt das Datum nicht zuverlässig.
    if (!origin || !dest) return 'https://www.google.com/travel/flights';
    const q = retDate && outDate
      ? `flights from ${origin} to ${dest} on ${outDate} returning ${retDate}`
      : outDate
        ? `flights from ${origin} to ${dest} on ${outDate}`
        : `flights from ${origin} to ${dest}`;
    return `https://www.google.com/travel/flights?hl=en&q=${encodeURIComponent(q)}`;
  },

  expediaFlights(origin, dest, outDate, retDate, cabin) {
    const fmt = this._fmtExpediaFlightDate;
    const cab = this._expediaCabin(cabin);
    if (!origin || !dest || !outDate) return 'https://www.expedia.com/Flights';
    return retDate
      ? `https://www.expedia.com/Flights-Search?trip=roundtrip&leg1=from:${origin},to:${dest},departure:${fmt(outDate)}TANYT&leg2=from:${dest},to:${origin},departure:${fmt(retDate)}TANYT&passengers=adults:1&options=cabinclass:${cab}&mode=search`
      : `https://www.expedia.com/Flights-Search?trip=oneway&leg1=from:${origin},to:${dest},departure:${fmt(outDate)}TANYT&passengers=adults:1&options=cabinclass:${cab}&mode=search`;
  },

  googleHotels(dest, checkin, checkout) {
    if (!dest) return 'https://www.google.com/travel/search';
    // "hotels in X from YYYY-MM-DD to YYYY-MM-DD" parst Google zuverlässiger als
    // "check in / check out" — das alte Format hat die Daten oft nicht übernommen.
    const q = checkin && checkout
      ? `hotels in ${dest} from ${checkin} to ${checkout}`
      : checkin
        ? `hotels in ${dest} from ${checkin}`
        : `hotels in ${dest}`;
    return `https://www.google.com/travel/search?q=${encodeURIComponent(q)}`;
  },

  bookingHotels(dest, checkin, checkout) {
    if (!dest) return 'https://www.booking.com';
    const params = [`ss=${encodeURIComponent(dest)}`];
    if (checkin) params.push(`checkin=${checkin}`);
    if (checkout) params.push(`checkout=${checkout}`);
    params.push('group_adults=2', 'no_rooms=1');
    return `https://www.booking.com/searchresults.html?${params.join('&')}`;
  },

  expediaHotels(dest, checkin, checkout) {
    if (!dest) return 'https://www.expedia.com/Hotels';
    const params = [`destination=${encodeURIComponent(dest)}`];
    if (checkin) params.push(`startDate=${checkin}`);
    if (checkout) params.push(`endDate=${checkout}`);
    params.push('rooms=1', 'adults=2');
    return `https://www.expedia.com/Hotel-Search?${params.join('&')}`;
  },

  expediaCars(city, pickupDate, dropoffDate) {
    if (!city) return 'https://www.expedia.com/Cars';
    return `https://www.expedia.com/carsearch?locn=${encodeURIComponent(city)}&date1=${pickupDate||''}&time1=1000AM&date2=${dropoffDate||''}&time2=1000AM`;
  },

  kayakCars(city, pickupDate, dropoffDate) {
    if (!city) return 'https://www.kayak.com/cars';
    return `https://www.kayak.com/cars/${encodeURIComponent(city)}/${pickupDate||''}/${dropoffDate||''}`;
  },

  // DiscoverCars: NICHT IM UI GENUTZT. Öffentliche Deep-Links mit Datum+Ort gibt es nicht;
  // die interne create-search-POST-API antwortet mit {success:false} für nicht authentifizierte
  // Aufrufe (getestet 2026-04-16). Richtige Integration nur über offiziellen Link-Generator
  // im DC-Affiliate-Dashboard — kommt nach Approval. Siehe memory: project_zercy_affiliate.md.
  discoverCars(city) {
    const AID = ''; // TODO: nach DC-Affiliate-Approval eintragen
    return AID ? `https://www.discovercars.com/?a_aid=${encodeURIComponent(AID)}` : 'https://www.discovercars.com/';
  },

  googleMaps(origin, dest, mode) {
    const m = mode || 'transit';
    return `https://www.google.com/maps/dir/${origin||''}/${dest||''}/?travelmode=${m}`;
  },

  googleMapsSearch(query) {
    return `https://www.google.com/maps/search/${encodeURIComponent(query||'')}`;
  },
};
