{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "functions": {
    "api/think.js": { "maxDuration": 60 },
    "api/parse.js": { "maxDuration": 60 },
    "api/chat.js": { "maxDuration": 30 },
    "api/ideas.js": { "maxDuration": 60 },
    "api/hotel-prices.js": { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/cron-keepalive", "schedule": "0 4 * * *" }
  ]
}
