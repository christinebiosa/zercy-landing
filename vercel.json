{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "functions": {
    "api/think.js": { "maxDuration": 60 },
    "api/parse.js": { "maxDuration": 60 },
    "api/chat.js": { "maxDuration": 30 },
    "api/ideas.js": { "maxDuration": 60 },
    "api/hotel-prices.js": { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/cron-keepalive", "schedule": "0 4 * * *" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "zercy.app" }],
      "destination": "https://www.zercy.app/:path*",
      "permanent": true
    },
    { "source": "/blog/:slug", "destination": "/blog/:slug/", "permanent": true },
    { "source": "/en/blog/:slug", "destination": "/en/blog/:slug/", "permanent": true },
    { "source": "/es/blog/:slug", "destination": "/es/blog/:slug/", "permanent": true }
  ]
}
